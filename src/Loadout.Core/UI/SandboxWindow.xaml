<Window x:Class="Loadout.UI.SandboxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loadout — Input sandbox"
        Width="520" Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource Brush.Bg.Window}"
        Foreground="#FFFFFF"
        FontFamily="Geist, Segoe UI, system-ui, sans-serif"
        FontSize="13"
        Focusable="True"
        KeyDown="OnKeyDown"
        KeyUp="OnKeyUp"
        MouseDown="OnMouseDown"
        MouseWheel="OnMouseWheel">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Loadout;component/UI/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Input sandbox" Style="{StaticResource H1}" />
        <TextBlock Grid.Row="1" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0 4 0 12">
            Click anywhere in this window to focus it, then have Loadout fire a game action.
            Every keystroke, click, and scroll wheel event the OS routes to this window appears
            below — exactly what your game would see. Pair with the "Test selected" button on
            the Game Interactions tab to verify a binding without launching the real game.
        </TextBlock>

        <Border Grid.Row="2" Background="{StaticResource Brush.Bg.Surface}"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                CornerRadius="6" Padding="8">
            <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="LogText" FontFamily="Consolas, ui-monospace, monospace" FontSize="12" TextWrapping="Wrap" />
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0 10 0 0">
            <Button Content="Clear log" Style="{StaticResource SecondaryButton}" Click="BtnClear_Click" Margin="0 0 8 0" />
            <TextBlock x:Name="TxtFocusHint" Style="{StaticResource Muted}" VerticalAlignment="Center" />
        </StackPanel>
    </Grid>
</Window>
