<Window x:Class="Loadout.UI.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loadout — Welcome"
        Width="780" Height="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="Window_Loaded"
        Opacity="1"
        FontFamily="Segoe UI"
        FontSize="13"
        Background="{DynamicResource Brush.Bg.Window}"
        Foreground="#EFEFF1"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextElement.Foreground="#EFEFF1">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Loadout;component/UI/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Step indicator -->
        <Border Grid.Row="0" Background="{StaticResource Brush.Bg.Surface}" Padding="24 18"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0 0 0 1">
            <StackPanel>
                <Grid>
                    <TextBlock Text="Loadout Setup" Style="{StaticResource H1}" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Ellipse x:Name="StepDot1" Width="9" Height="9" Margin="0 0 6 0" Fill="{StaticResource Brush.Accent}" />
                        <Ellipse x:Name="StepDot2" Width="9" Height="9" Margin="0 0 6 0" Fill="{StaticResource Brush.Border.Strong}" />
                        <Ellipse x:Name="StepDot3" Width="9" Height="9" Margin="0 0 6 0" Fill="{StaticResource Brush.Border.Strong}" />
                        <Ellipse x:Name="StepDot4" Width="9" Height="9" Margin="0 0 6 0" Fill="{StaticResource Brush.Border.Strong}" />
                        <Ellipse x:Name="StepDot5" Width="9" Height="9" Margin="0 0 6 0" Fill="{StaticResource Brush.Border.Strong}" />
                        <Ellipse x:Name="StepDot6" Width="9" Height="9" Margin="0 0 6 0" Fill="{StaticResource Brush.Border.Strong}" />
                        <Ellipse x:Name="StepDot7" Width="9" Height="9" Margin="0 0 6 0" Fill="{StaticResource Brush.Border.Strong}" />
                        <Ellipse x:Name="StepDot8" Width="9" Height="9" Fill="{StaticResource Brush.Border.Strong}" />
                    </StackPanel>
                </Grid>
                <TextBlock x:Name="StepLabel" Text="Step 1 of 8 — Welcome" Style="{StaticResource Muted}" Margin="0 4 0 0" />
            </StackPanel>
        </Border>

        <!-- Step content -->
        <Grid Grid.Row="1" Margin="32 24">
            <!-- Step 1: Welcome — pro-grade landing screen.
                 Layout: brand wordmark + tagline → friendly intro → an
                 at-a-glance "what we'll set up" card with time estimate
                 + reassurance that nothing's permanent. -->
            <StackPanel x:Name="Step1" Visibility="Visible">
                <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                    <TextBlock Text="⚡" FontSize="32" Margin="0 0 10 0" VerticalAlignment="Center"
                               Foreground="{StaticResource Brush.Accent}" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="L O A D O U T" FontSize="22" FontWeight="Bold" />
                        <TextBlock Text="Your stream's command deck" Style="{StaticResource Muted}" Margin="0 -2 0 0" />
                    </StackPanel>
                </StackPanel>
                <TextBlock Text="Let's get you set up." Style="{StaticResource H1}" Margin="0 14 0 6" />
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 16">
                    Loadout is a complete Streamer.bot suite — info commands, alerts, timed messages,
                    a unified bolts wallet, an off-stream Discord bot, eleven OBS overlays, and more.
                    Everything works across <Bold>Twitch</Bold>, <Bold>TikTok</Bold>, <Bold>YouTube</Bold>,
                    and <Bold>Kick</Bold> from a single import.
                </TextBlock>

                <Border Style="{StaticResource Card}" Margin="0 8 0 0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 4">
                            <TextBlock Text="🧭" FontSize="14" Margin="0 0 8 0" />
                            <TextBlock Text="What we'll do" Style="{StaticResource H2}" Margin="0" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource Muted}" FontSize="12" TextWrapping="Wrap" Margin="0 0 0 8"
                                   Text="Eight short steps, about 3 minutes. Skip any you don't need — you can fill them in later." />
                        <TextBlock Margin="0 2" Text="① Pick your platforms (Twitch / TikTok / YouTube / Kick)" />
                        <TextBlock Margin="0 2" Text="② Choose which features start enabled (recommended presets included)" />
                        <TextBlock Margin="0 2" Text="③ Connect a Discord channel for go-live posts (optional)" />
                        <TextBlock Margin="0 2" Text="④ Open a local port for tip webhooks (optional)" />
                        <TextBlock Margin="0 2" Text="⑤ Drop in your socials + gamer tags (optional)" />
                        <TextBlock Margin="0 2" Text="⑥ Connect Patreon for early access to new features (optional)" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0 12 0 0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💡" FontSize="14" Margin="0 0 10 0" VerticalAlignment="Top" />
                        <StackPanel>
                            <TextBlock Text="Nothing's locked in" FontWeight="SemiBold" />
                            <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" FontSize="12" Margin="0 2 0 0"
                                       Text="Every choice here lands in Settings. Re-open this wizard any time from the tray-icon menu, or just tweak the saved value directly. Loadout ships with everything OFF — you opt in." />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Step 2: Platforms -->
            <StackPanel x:Name="Step2" Visibility="Collapsed">
                <TextBlock Text="Which platforms do you stream on?" Style="{StaticResource H1}" />
                <TextBlock Style="{StaticResource Muted}" Margin="0 0 0 16">
                    Loadout will only listen to and post on platforms you enable here. You can flip these any time.
                </TextBlock>
                <CheckBox x:Name="ChkTwitch"  Content="Twitch"   Style="{StaticResource ToggleRow}" />
                <CheckBox x:Name="ChkTikTok"  Content="TikTok (via TikFinity)"  Style="{StaticResource ToggleRow}" />
                <CheckBox x:Name="ChkYouTube" Content="YouTube"  Style="{StaticResource ToggleRow}" />
                <CheckBox x:Name="ChkKick"    Content="Kick"     Style="{StaticResource ToggleRow}" />

                <Border Style="{StaticResource Card}" Margin="0 24 0 0">
                    <StackPanel>
                        <TextBlock Text="Your broadcaster name" Style="{StaticResource H2}" />
                        <TextBlock Style="{StaticResource Muted}" Margin="0 0 0 6"
                                   Text="Used in welcomes, recaps, and Discord posts. Usually your Twitch login." />
                        <TextBox x:Name="TxtBroadcaster" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Step 3: Modules — grouped by category for scannability.
                 Three preset buttons drive the most common starting
                 points: Essentials (5 core modules), Recommended (the
                 default for active streamers), and Everything. Subhead
                 captions explain each category in plain language. -->
            <StackPanel x:Name="Step3" Visibility="Collapsed">
                <TextBlock Text="Pick what comes on by default" Style="{StaticResource H1}" />
                <TextBlock Style="{StaticResource Muted}" Margin="0 0 0 12" TextWrapping="Wrap">
                    Loadout ships with everything OFF. Pick a preset or tick individual modules — every toggle is also available later in Settings → Modules.
                </TextBlock>
                <StackPanel Orientation="Horizontal" Margin="0 0 0 14">
                    <Button Content="Essentials"   Style="{StaticResource SecondaryButton}" Click="BtnPresetEssentials_Click"  Margin="0 0 8 0"
                            ToolTip="Just the basics: info commands, welcomes, alerts, timed messages, counters. Good for a brand-new install." />
                    <Button Content="Recommended"  Style="{StaticResource PrimaryButton}"   Click="BtnPresetRecommended_Click" Margin="0 0 8 0"
                            ToolTip="The default for an active streamer — adds bolts, goals, daily check-in, hype train, sub anniversary milestones." />
                    <Button Content="Everything"   Style="{StaticResource SecondaryButton}" Click="BtnPresetAll_Click"         Margin="0 0 8 0"
                            ToolTip="Enable every module. You'll likely want to come back and trim later." />
                    <Button Content="Clear all"    Style="{StaticResource SecondaryButton}" Click="BtnPresetNone_Click"
                            ToolTip="Untick everything — start clean." />
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="340">
                    <StackPanel>
                        <!-- ─── Core ─── -->
                        <TextBlock Text="CORE" Style="{StaticResource Eyebrow}" Margin="0 0 0 4" />
                        <CheckBox x:Name="ChkInfo"     Content="Info commands — !uptime, !followage, !socials, custom commands"           Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ChkWelcomes" Content="Welcomes — first-time / returning / sub / VIP / mod"                      Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ChkAlerts"   Content="Alerts — follows / subs / cheers / raids / super chats / TikTok gifts"    Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ChkTimers"   Content="Auto-timed messages — randomized cadence with activity gating"             Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ChkFun"      Content="Counters — !deaths / !wins / custom, chat increment + overlay"             Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ChkGoals"    Content="Goals — followers / subs / bits trackers with live overlay"                Style="{StaticResource ToggleRow}" />

                        <!-- ─── Engagement loops ─── -->
                        <TextBlock Text="ENGAGEMENT" Style="{StaticResource Eyebrow}" Margin="0 12 0 4" />
                        <CheckBox x:Name="ChkLoyalty"   Content="Bolts wallet — unified cross-platform points + minigames"   Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ChkCheckIn"   Content="Daily check-in — !checkin or channel-point reward"          Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ChkHype"      Content="Hype train — cross-platform fuel from Twitch + TikTok + YouTube + Kick" Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ChkSubRaid"   Content="Sub raid train — 3+/6+/10+/20+ in 60s detection"             Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ChkSubAnniv"  Content="Sub anniversary milestones — auto-celebrate 3/6/12/24+ mo"   Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ChkApex"      Content="Apex — top-viewer mode with cross-platform damage"           Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ChkFirstWords" Content="First-words celebration — Twitch + YouTube native"          Style="{StaticResource ToggleRow}" />

                        <!-- ─── Off-stream + integrations ─── -->
                        <TextBlock Text="OFF-STREAM + INTEGRATIONS" Style="{StaticResource Eyebrow}" Margin="0 12 0 4" />
                        <CheckBox x:Name="ChkDiscord"   Content="Discord live-status auto-poster — go-live embed + edit + archive" Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ChkRecap"     Content="Stream recap — post-stream summary to Discord"                    Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ChkWebhook"   Content="Webhook inbox — Ko-fi / Throne / Patreon / Streamlabs in-bound"    Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ChkAdBreak"   Content="Ad-break heads-up — chat warning + countdown overlay"             Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ChkAutoPoll"  Content="Auto-poll on category change — chat reaction prompt"             Style="{StaticResource ToggleRow}" />

                        <!-- ─── Safety + meta ─── -->
                        <TextBlock Text="SAFETY + META" Style="{StaticResource Eyebrow}" Margin="0 12 0 4" />
                        <CheckBox x:Name="ChkMod"       Content="Hate-raid detector — pattern-based, broadcaster DM only" Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ChkVip"       Content="VIP rotation auto-magic — weekly engagement-based promo"  Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ChkCcCoins"   Content="Crowd Control coin tracker — !mycoins / !cccoins leaderboard"      Style="{StaticResource ToggleRow}" />
                    </StackPanel>
                </ScrollViewer>

                <Border Style="{StaticResource Card}" Margin="0 14 0 0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💡" FontSize="14" Margin="0 0 10 0" VerticalAlignment="Top" />
                        <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" FontSize="12"
                                   Text="Every module here is free for everyone — tick whatever you want. Patreon supporters just get brand-new features a little earlier." />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Step 4: Discord -->
            <StackPanel x:Name="Step4" Visibility="Collapsed">
                <TextBlock Text="Discord live-status (optional)" Style="{StaticResource H1}" />
                <TextBlock Style="{StaticResource Muted}" Margin="0 0 0 16" TextWrapping="Wrap">
                    Paste a Discord webhook URL and Loadout will post a "live now" embed when you go live,
                    edit it when title/category changes, and archive it when you go offline. Skip this and you can add it later.
                </TextBlock>
                <TextBlock Text="Webhook URL" Style="{StaticResource H2}" />
                <TextBox x:Name="TxtDiscordWebhook" />
                <TextBlock Margin="0 12 0 4" Text="Go-live message template" Style="{StaticResource H2}" />
                <TextBox x:Name="TxtDiscordTemplate" AcceptsReturn="True" Height="70" TextWrapping="Wrap" />
                <TextBlock Style="{StaticResource Muted}" Margin="0 4 0 0">
                    Variables: {broadcaster} {title} {game} {url}
                </TextBlock>
            </StackPanel>

            <!-- Step 5: Webhook inbox -->
            <StackPanel x:Name="Step5" Visibility="Collapsed">
                <TextBlock Text="Webhook inbox (optional)" Style="{StaticResource H1}" />
                <TextBlock Style="{StaticResource Muted}" Margin="0 0 0 16" TextWrapping="Wrap">
                    Loadout can listen on a local port and trigger SB actions when external services
                    (Ko-fi, Throne, Patreon, custom) hit it. Map paths → actions in Settings later.
                </TextBlock>
                <TextBlock Text="Listen port" Style="{StaticResource H2}" />
                <TextBox x:Name="TxtWebhookPort" Text="7474" />
                <TextBlock Margin="0 12 0 4" Text="Shared secret (recommended)" Style="{StaticResource H2}" />
                <TextBox x:Name="TxtWebhookSecret" />
                <TextBlock Style="{StaticResource Muted}" Margin="0 4 0 0" TextWrapping="Wrap">
                    Senders include this in an X-Loadout-Secret header. Leave blank to allow unauthenticated requests
                    (only safe if you bind to localhost).
                </TextBlock>
            </StackPanel>

            <!-- Step 6: Your links (socials + gamer tags) -->
            <StackPanel x:Name="Step6" Visibility="Collapsed">
                <TextBlock Text="Your channel links (optional)" Style="{StaticResource H1}" />
                <TextBlock Style="{StaticResource Muted}" Margin="0 0 0 12" TextWrapping="Wrap">
                    Drop in whatever you want chat to find. The commands ticker shows the real brand
                    logos for each link you fill in — Twitter shows the X bird, Bluesky the butterfly,
                    Steam the gear, etc. Skip what you don't have; add more later in Settings.
                </TextBlock>

                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="380">
                    <StackPanel>
                        <Border Style="{StaticResource Card}" Margin="0 0 0 12">
                            <StackPanel>
                                <TextBlock Text="!socials" Style="{StaticResource H2}" />
                                <TextBlock Style="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="0 0 0 8">
                                    Type the @handle or full URL. Whatever's filled in gets the brand logo on the ticker.
                                </TextBlock>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" /><ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" /><ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Discord invite" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 4 8 0" />
                                    <TextBox  Grid.Row="0" Grid.Column="1" x:Name="TxtSocDiscord"   Margin="0 4 12 0" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Twitter / X"     Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 4 8 0" />
                                    <TextBox  Grid.Row="0" Grid.Column="3" x:Name="TxtSocTwitter"   Margin="0 4 0 0" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Instagram"        Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 4 8 0" />
                                    <TextBox  Grid.Row="1" Grid.Column="1" x:Name="TxtSocInstagram" Margin="0 4 12 0" />
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="TikTok"           Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 4 8 0" />
                                    <TextBox  Grid.Row="1" Grid.Column="3" x:Name="TxtSocTikTok"    Margin="0 4 0 0" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="YouTube"          Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 4 8 0" />
                                    <TextBox  Grid.Row="2" Grid.Column="1" x:Name="TxtSocYouTube"   Margin="0 4 12 0" />
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Bluesky"          Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 4 8 0" />
                                    <TextBox  Grid.Row="2" Grid.Column="3" x:Name="TxtSocBluesky"   Margin="0 4 0 0" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Threads"          Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 4 8 0" />
                                    <TextBox  Grid.Row="3" Grid.Column="1" x:Name="TxtSocThreads"   Margin="0 4 12 0" />
                                    <TextBlock Grid.Row="3" Grid.Column="2" Text="Patreon"          Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 4 8 0" />
                                    <TextBox  Grid.Row="3" Grid.Column="3" x:Name="TxtSocPatreon"   Margin="0 4 0 0" />
                                </Grid>
                                <TextBlock Style="{StaticResource Muted}" FontSize="10" Margin="0 8 0 0" TextWrapping="Wrap"
                                           Text="More platforms (Kick, GitHub, Spotify, SoundCloud, Throne, Ko-fi…) live in Settings → Info commands → Your socials." />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="!gamertags" Style="{StaticResource H2}" />
                                    <CheckBox x:Name="ChkOnbGamerTagsEnabled" HorizontalAlignment="Right"
                                              Content="Enable !gamertags command"
                                              Style="{StaticResource ToggleSwitch}" />
                                </Grid>
                                <TextBlock Style="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="0 0 0 8">
                                    For viewers to friend you. Each filled tag shows up with the real platform logo.
                                </TextBlock>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" /><ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" /><ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="PSN"      Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 4 8 0" />
                                    <TextBox  Grid.Row="0" Grid.Column="1" x:Name="TxtTagPsn"     Margin="0 4 12 0" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Xbox"     Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 4 8 0" />
                                    <TextBox  Grid.Row="0" Grid.Column="3" x:Name="TxtTagXbox"    Margin="0 4 0 0" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Steam"    Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 4 8 0" />
                                    <TextBox  Grid.Row="1" Grid.Column="1" x:Name="TxtTagSteam"   Margin="0 4 12 0" />
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Riot"     Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 4 8 0" />
                                    <TextBox  Grid.Row="1" Grid.Column="3" x:Name="TxtTagRiot"    Margin="0 4 0 0" />
                                </Grid>
                                <TextBlock Style="{StaticResource Muted}" FontSize="10" Margin="0 8 0 0" TextWrapping="Wrap"
                                           Text="More platforms (Valorant, LoL, Minecraft, Fortnite, Nintendo Switch, Epic, Battle.net, Ubisoft, EA, Rockstar, Bethesda, GOG, itch.io) live in Settings → Info commands → !gamertags." />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </StackPanel>

            <!-- Step 7: Patreon -->
            <StackPanel x:Name="Step7" Visibility="Collapsed">
                <TextBlock Text="Connect Patreon (optional)" Style="{StaticResource H1}" />
                <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0 0 0 16">
                    Every Loadout feature is free for everyone — you don't need to sign in to use anything.
                    Connecting Patreon is for supporters: Tier 2 and Tier 3 patrons get brand-new features early,
                    earn Bolts at a boosted rate, and help fund development. You can connect later from Settings.
                </TextBlock>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock x:Name="TxtPatreonStatus" Style="{StaticResource Muted}" Margin="0 0 0 12" />
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BtnPatreonConnect" Content="Connect Patreon"
                                    Style="{StaticResource PrimaryButton}" Click="BtnPatreonConnect_Click"
                                    Margin="0 0 8 0" />
                            <Button x:Name="BtnPatreonSkip" Content="Skip for now"
                                    Style="{StaticResource SecondaryButton}" Click="BtnPatreonSkip_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>
                <TextBlock Style="{StaticResource Muted}" Margin="0 16 0 0" TextWrapping="Wrap">
                    Sign-in opens in your default browser. Loadout never sees your password — Patreon does the auth.
                </TextBlock>
            </StackPanel>

            <!-- Step 8: Done -->
            <StackPanel x:Name="Step8" Visibility="Collapsed">
                <TextBlock Text="You're ready 🎉" Style="{StaticResource H1}" />
                <TextBlock TextWrapping="Wrap" Margin="0 8 0 16">
                    Loadout is configured. The tray icon (bottom-right of your screen) is your hub —
                    right-click any time for quick toggles or to open Settings.
                </TextBlock>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Next steps" Style="{StaticResource H2}" />
                        <TextBlock Text="• Test a command in chat: !uptime" Margin="0 2" />
                        <TextBlock Text="• Edit timed messages in Settings → Timers" Margin="0 2" />
                        <TextBlock Text="• Customize alerts in Settings → Alerts" Margin="0 2" />
                        <TextBlock Text="• Map webhook paths in Settings → Webhooks" Margin="0 2" />
                    </StackPanel>
                </Border>
                <CheckBox x:Name="ChkOpenSettings" Content="Open Settings now" IsChecked="True"
                          Style="{StaticResource ToggleRow}" Margin="0 16 0 0" />
            </StackPanel>
        </Grid>

        <!-- Nav -->
        <Border Grid.Row="2" Background="{StaticResource Brush.Bg.Surface}" Padding="24 16"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0 1 0 0">
            <Grid>
                <Button x:Name="BtnSkip"  Content="Skip setup" Style="{StaticResource SecondaryButton}"
                        HorizontalAlignment="Left" Click="BtnSkip_Click" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnBack" Content="Back" Style="{StaticResource SecondaryButton}"
                            Margin="0 0 8 0" Click="BtnBack_Click" />
                    <Button x:Name="BtnNext" Content="Next" Style="{StaticResource PrimaryButton}"
                            Click="BtnNext_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
