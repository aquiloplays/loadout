                                    <TextBox  Grid.Column="1" x:Name="TxtWalletDelta" Margin="0 0 12 0" />
                                    <TextBlock Grid.Column="2" Text="Reason:" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 0 8 0" />
                                    <TextBox  Grid.Column="3" x:Name="TxtWalletReason" />
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0 8 0 0">
                                    <Button Content="Apply" Style="{StaticResource PrimaryButton}" Click="BtnWalletApply_Click" Margin="0 0 8 0" />
