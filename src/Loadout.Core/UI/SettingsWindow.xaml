<Window x:Class="Loadout.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loadout Settings"
        Width="1180" Height="780"
        MinWidth="1080" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="Window_Loaded"
        Opacity="1"
        FontFamily="Segoe UI"
        FontSize="13"
        Background="{DynamicResource Brush.Bg.Window}"
        Foreground="#F5F5F7"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextElement.Foreground="#F5F5F7">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Loadout;component/UI/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ============================ HEADER ============================ -->
        <Border Grid.Row="0" Background="{StaticResource Brush.HeaderBackground}" Padding="22 14"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0 0 0 1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Logo + wordmark. The Image source is set in code-behind from
                     an embedded resource stream - see SettingsWindow.LoadHeaderLogo.
                     Avoids fragile pack:// URI resolution in plugin-loaded DLLs. -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image x:Name="HeaderLogo"
                           Width="40" Height="40" Margin="0 0 14 0" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Loadout" Style="{StaticResource Wordmark}"
                                   Foreground="{StaticResource Brush.Brand.Gradient}" />
                        <TextBlock x:Name="TxtVersionLine"
                                   Text="Version 0.1.0 - checking for updates..."
                                   Style="{StaticResource Faint}" Margin="0 1 0 0" />
                    </StackPanel>
                </StackPanel>

                <!-- Status pills -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                            HorizontalAlignment="Left" Margin="28 0 0 0">
                    <Border Style="{StaticResource PillAccent}" Margin="0 0 8 0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◆" FontSize="10" Foreground="{StaticResource Brush.Accent}"
                                       VerticalAlignment="Center" Margin="0 0 6 0" />
                            <TextBlock x:Name="TxtPillTier" Text="Free" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.Fg.Primary}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Pill}" Margin="0 0 8 0">
                        <TextBlock x:Name="TxtPillChannel" Text="stable" FontSize="11"
                                   Foreground="{StaticResource Brush.Fg.Muted}" VerticalAlignment="Center" />
                    </Border>
                    <Border x:Name="PillBus" Style="{StaticResource PillSuccess}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="{StaticResource Brush.Success}"
                                     VerticalAlignment="Center" Margin="0 0 6 0" />
                            <TextBlock x:Name="TxtPillBus" Text="Bus :7470" FontSize="11"
                                       Foreground="{StaticResource Brush.Fg.Muted}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Header actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Variables" Style="{StaticResource SecondaryButton}"
                            Margin="0 0 8 0" Click="BtnVariables_Click"
                            ToolTip="Quick reference of {user}, {tier}, {bits}, etc. for any template field." />
                    <Button Content="Re-run onboarding" Style="{StaticResource SecondaryButton}"
                            Margin="0 0 8 0" Click="BtnReonboard_Click" />
                    <Button Content="Check for updates" Style="{StaticResource SecondaryButton}"
                            Click="BtnCheckUpdate_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================ BODY (sidebar nav) ============================ -->
        <TabControl Grid.Row="1" x:Name="MainTabs"
                    Style="{StaticResource SidebarNavTabControl}"
                    Background="Transparent" BorderThickness="0">

            <!-- ============ SETUP ============ -->
            <TabItem Style="{StaticResource SidebarNavSectionHeader}">
                <TabItem.Header>
                    <TextBlock Text="SETUP" Style="{StaticResource SidebarGroupLabel}" />
                </TabItem.Header>
            </TabItem>

            <!-- Health dashboard: at-a-glance status of every module. New
                 landing tab so a streamer opening Loadout sees what's wired
                 up before drilling into individual settings. -->
            <TabItem Style="{StaticResource SidebarNavTabItem}" IsSelected="True">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource Icon}" Data="{StaticResource IconGeo.Modules}" Margin="0 0 10 0" />
                        <TextBlock Text="Health" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32 28" MaxWidth="900" HorizontalAlignment="Left">
                        <TextBlock Text="Module health" Style="{StaticResource H1}" />
                        <TextBlock x:Name="TxtHealthSummary" Style="{StaticResource Muted}"
                                   Margin="0 0 0 14" TextWrapping="Wrap"
                                   Text="Counting modules…" />
                        <Border Style="{StaticResource Card}" Margin="0 0 0 14">
                            <StackPanel x:Name="HealthList" />
                        </Border>
                        <Border Style="{StaticResource Card}" Margin="0 0 0 14">
                            <StackPanel>
                                <TextBlock Text="Diagnostics" Style="{StaticResource H2}" />
                                <CheckBox x:Name="ChkDryRun" Style="{StaticResource ToggleSwitch}"
                                          Content="Dry-run mode (log chat sends instead of posting)"
                                          Margin="0 8 0 0" Click="ChkDryRun_Click" />
                                <TextBlock Style="{StaticResource Muted}" Margin="0 4 0 0" TextWrapping="Wrap">
                                    Useful while testing alerts or auto-messages — every chat-bound send is
                                    logged to the error log instead of going out, so chat stays quiet.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Refresh" Style="{StaticResource SecondaryButton}"
                                    Click="BtnHealthRefresh_Click" Margin="0 0 8 0" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Style="{StaticResource SidebarNavTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource Icon}" Data="{StaticResource IconGeo.General}" Margin="0 0 10 0" />
                        <TextBlock Text="General" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32 28" MaxWidth="780" HorizontalAlignment="Left">
                        <TextBlock Text="General" Style="{StaticResource H1}" />
                        <TextBlock Style="{StaticResource Muted}" Margin="0 0 0 18" TextWrapping="Wrap">
                            Your channel identity and which platforms Loadout reads + writes to.
                        </TextBlock>

                        <Border Style="{StaticResource Card}" Margin="0 0 0 14">
                            <StackPanel>
                                <TextBlock Text="Broadcaster name" Style="{StaticResource H2}" />
                                <TextBlock Style="{StaticResource Muted}" Margin="0 0 0 6" TextWrapping="Wrap">
                                    Used in {broadcaster} placeholders across alerts, recaps, and Discord posts.
                                </TextBlock>
                                <TextBox x:Name="TxtBroadcaster" Width="320" HorizontalAlignment="Left" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0 0 0 14">
                            <StackPanel>
                                <TextBlock Text="Platforms" Style="{StaticResource H2}" />
                                <TextBlock Style="{StaticResource Muted}" Margin="0 0 0 8" TextWrapping="Wrap">
                                    Loadout fans events out to whichever of these are connected in Streamer.bot.
                                    Untick a platform to mute Loadout output to it without disconnecting it in SB.
                                </TextBlock>
                                <CheckBox x:Name="ChkTwitch"  Content="Twitch"   Style="{StaticResource ToggleRow}" />
                                <CheckBox x:Name="ChkTikTok"  Content="TikTok (read-only via TikFinity)" Style="{StaticResource ToggleRow}" />
                                <CheckBox x:Name="ChkYouTube" Content="YouTube"  Style="{StaticResource ToggleRow}" />
                                <CheckBox x:Name="ChkKick"    Content="Kick"     Style="{StaticResource ToggleRow}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Updates" Style="{StaticResource H2}" />
                                <Grid Margin="0 0 0 8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Channel:" Style="{StaticResource Muted}"
                                               VerticalAlignment="Center" Margin="0 0 12 0" />
                                    <ComboBox Grid.Column="1" x:Name="CmbChannel" Width="220" HorizontalAlignment="Left">
                                        <ComboBoxItem Content="Stable" Tag="stable" />
                                        <ComboBoxItem Content="Beta"   Tag="beta" />
                                    </ComboBox>
                                </Grid>
                                <CheckBox x:Name="ChkAutoCheckUpdates" Content="Check for updates on boot + every 6h"
                                          Style="{StaticResource ToggleSwitch}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Style="{StaticResource SidebarNavTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource Icon}" Data="{StaticResource IconGeo.Modules}" Margin="0 0 10 0" />
                        <TextBlock Text="Modules" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32 28" MaxWidth="900">
                        <TextBlock Text="Modules" Style="{StaticResource H1}" />
                        <TextBlock Style="{StaticResource Muted}" Margin="0 0 0 18" TextWrapping="Wrap">
                            Master kill-switch per module. Anything off here will not run, regardless of its
                            individual tab settings. Most modules ship off; turn on what you'll actually use.
                        </TextBlock>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0 0 12 0">
                                <TextBlock Text="CHAT &amp; ENGAGEMENT" Style="{StaticResource H3}" Margin="0 0 0 4" />
                                <CheckBox x:Name="ModInfo"     Content="Info commands"          Style="{StaticResource ToggleSwitch}" />
                                <CheckBox x:Name="ModWelcomes" Content="Context-aware welcomes" Style="{StaticResource ToggleSwitch}" />
                                <CheckBox x:Name="ModFun"      Content="Fun commands"           Style="{StaticResource ToggleSwitch}" />
                                <CheckBox x:Name="ModFirstWords" Content="First words tracker"  Style="{StaticResource ToggleSwitch}" />
                                <CheckBox x:Name="ModAutoPoll" Content="Auto polls"             Style="{StaticResource ToggleSwitch}" />

                                <TextBlock Text="EVENTS" Style="{StaticResource H3}" />
                                <CheckBox x:Name="ModAlerts"   Content="Alerts"                 Style="{StaticResource ToggleSwitch}" />
                                <CheckBox x:Name="ModTimers"   Content="Auto-timed messages"    Style="{StaticResource ToggleSwitch}" />
                                <CheckBox x:Name="ModGoals"    Content="Goals"                  Style="{StaticResource ToggleSwitch}" />
                                <CheckBox x:Name="ModCounters" Content="Counters"               Style="{StaticResource ToggleSwitch}" />
                                <CheckBox x:Name="ModSubAnniv" Content="Sub anniversary"        Style="{StaticResource ToggleSwitch}" />
                                <CheckBox x:Name="ModSubRaidTrain" Content="Sub raid train"     Style="{StaticResource ToggleSwitch}" />

                                <TextBlock Text="WALLET &amp; TOP VIEWER" Style="{StaticResource H3}" />
                                <CheckBox x:Name="ModBolts"    Content="Bolts wallet"           Style="{StaticResource ToggleSwitch}" />
                                <CheckBox x:Name="ModLoyalty"  Content="Legacy loyalty wallet"  Style="{StaticResource ToggleSwitch}" />
                                <CheckBox x:Name="ModApex"     Content="Apex top viewer"        Style="{StaticResource ToggleSwitch}" />
                                <CheckBox x:Name="ModCheckIn"  Content="Daily check-in"         Style="{StaticResource ToggleSwitch}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="LIVE OPS" Style="{StaticResource H3}" Margin="0 0 0 4" />
                                <CheckBox x:Name="ModHype"     Content="TikTok hype train"      Style="{StaticResource ToggleSwitch}" />
                                <CheckBox x:Name="ModHateRaid" Content="Hate-raid detector"     Style="{StaticResource ToggleSwitch}" />
                                <CheckBox x:Name="ModAdBreak"  Content="Ad break helper"        Style="{StaticResource ToggleSwitch}" />
                                <CheckBox x:Name="ModChatVel"  Content="Chat velocity tracker"  Style="{StaticResource ToggleSwitch}" />
                                <CheckBox x:Name="ModVip"      Content="VIP rotation"           Style="{StaticResource ToggleSwitch}" />
                                <CheckBox x:Name="ModMod"      Content="Moderation pack"        Style="{StaticResource ToggleSwitch}" />
                                <CheckBox x:Name="ModCcCoin"   Content="CC coin tracker"        Style="{StaticResource ToggleSwitch}" />

                                <TextBlock Text="CONTENT" Style="{StaticResource H3}" />
                                <CheckBox x:Name="ModClips"    Content="Clip on demand (!clip)" Style="{StaticResource ToggleSwitch}" />
                                <CheckBox x:Name="ModRecap"    Content="Stream recap"           Style="{StaticResource ToggleSwitch}" />
                                <CheckBox x:Name="ModGameTracker" Content="Game / category tracker" Style="{StaticResource ToggleSwitch}" />

                                <TextBlock Text="ROUTING" Style="{StaticResource H3}" />
                                <CheckBox x:Name="ModDiscord"  Content="Discord live status"    Style="{StaticResource ToggleSwitch}" />
                                <CheckBox x:Name="ModTwitter"  Content="Twitter / X live status" Style="{StaticResource ToggleSwitch}" />
                                <CheckBox x:Name="ModWebhook"  Content="Webhook inbox"          Style="{StaticResource ToggleSwitch}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Style="{StaticResource SidebarNavTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource Icon}" Data="{StaticResource IconGeo.Patreon}" Margin="0 0 10 0" />
                        <TextBlock Text="Patreon" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32 28" MaxWidth="780">
                        <TextBlock Text="Loadout Plus / Pro" Style="{StaticResource H1}" />
                        <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0 0 0 18">
                            Loadout's free tier covers info commands, Twitch alerts, basic welcomes, and 3 timed messages.
                            Tier 2 ($6) unlocks multi-platform routing, unlimited timers, Discord live status, webhook inbox, and stream recap.
                            Tier 3 ($10) adds hate-raid detection, TikTok hype train, the cross-platform Bolts wallet, and Apex top-viewer mode.
                        </TextBlock>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Status" Style="{StaticResource H2}" />
                                <TextBlock x:Name="TxtPatreonTier"   Style="{StaticResource Muted}" />
                                <TextBlock x:Name="TxtPatreonName"   Style="{StaticResource Muted}" Margin="0 4 0 0" />
                                <TextBlock x:Name="TxtPatreonReason" Style="{StaticResource Muted}" Margin="0 4 0 0" />
                                <StackPanel Orientation="Horizontal" Margin="0 14 0 0">
                                    <Button x:Name="BtnPatreonConnect" Content="Connect Patreon"
                                            Style="{StaticResource PrimaryButton}" Click="BtnPatreonConnect_Click"
                                            Margin="0 0 8 0" />
                                    <Button x:Name="BtnPatreonRefresh" Content="Re-check tier"
                                            Style="{StaticResource SecondaryButton}" Click="BtnPatreonRefresh_Click"
                                            Margin="0 0 8 0" />
                                    <Button x:Name="BtnPatreonSignOut" Content="Sign out"
                                            Style="{StaticResource SecondaryButton}" Click="BtnPatreonSignOut_Click" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="What unlocks" Style="{StaticResource H2}" Margin="0 22 0 8" />
                        <ItemsControl x:Name="LstFeatures" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Style="{StaticResource SidebarNavTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource Icon}" Data="{StaticResource IconGeo.Identity}" Margin="0 0 10 0" />
                        <TextBlock Text="Identity" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32 28" MaxWidth="780">
                        <TextBlock Text="Identity links" Style="{StaticResource H1}" />
                        <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0 0 0 18">
                            Viewers run <Bold>!link &lt;platform&gt; &lt;username&gt;</Bold> to connect their accounts across
                            platforms. Once linked, Loadout can attribute Bolts, sub anniversary, raid history,
                            and check-in history to a single identity.
                        </TextBlock>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Pending requests" Style="{StaticResource H2}" />
                                <TextBlock x:Name="TxtPendingLinks" Style="{StaticResource Muted}" Margin="0 4 0 0" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============ CHAT ============ -->
            <TabItem Style="{StaticResource SidebarNavSectionHeader}">
                <TabItem.Header><TextBlock Text="CHAT" Style="{StaticResource SidebarGroupLabel}" /></TabItem.Header>
            </TabItem>

            <TabItem Style="{StaticResource SidebarNavTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource Icon}" Data="{StaticResource IconGeo.Welcomes}" Margin="0 0 10 0" />
                        <TextBlock Text="Welcomes" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32 28" MaxWidth="780">
                        <TextBlock Text="Welcomes" Style="{StaticResource H1}" />
                        <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0 0 0 18">
                            One greeting per viewer per stream, picked by their role. Use {user} for the viewer's name.
                            Leave a template empty to skip welcomes for that role.
                        </TextBlock>
                        <Border Style="{StaticResource Card}" Margin="0 0 0 14">
                            <StackPanel>
                                <CheckBox x:Name="ChkWelcomesEnabled" Content="Welcomes enabled" Style="{StaticResource ToggleSwitch}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}" Margin="0 0 0 14">
                            <StackPanel>
                                <TextBlock Text="Follow batches (raid burst)" Style="{StaticResource H2}" />
                                <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0 0 0 8">
                                    Coalesce a follow burst into one summary line instead of N individual alerts.
                                    The bus still fires every individual follow event so overlays animate normally;
                                    only the chat post is collapsed. Placeholders: {count} {users}.
                                </TextBlock>
                                <CheckBox x:Name="ChkFollowBatchEnabled" Content="Batch follows during a burst" Style="{StaticResource ToggleSwitch}" />
                                <Grid Margin="0 8 0 0">
                                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="160" /></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Window (seconds after first follow)" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 6 12 0" />
                                    <TextBox  Grid.Row="0" Grid.Column="1" x:Name="TxtFollowBatchWindow" Margin="0 4 0 0" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Minimum follows to trigger batch"     Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 6 12 0" />
                                    <TextBox  Grid.Row="1" Grid.Column="1" x:Name="TxtFollowBatchMin"    Margin="0 4 0 0" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Max names shown in chat"               Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 6 12 0" />
                                    <TextBox  Grid.Row="2" Grid.Column="1" x:Name="TxtFollowBatchMaxNames" Margin="0 4 0 0" />
                                </Grid>
                                <TextBlock Text="Template" Style="{StaticResource Muted}" Margin="0 12 0 4" />
                                <TextBox x:Name="TxtFollowBatchTemplate" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="First time" Style="{StaticResource H2}" />
                                <TextBox x:Name="TxtWelcomeFirstTime" />
                                <TextBlock Text="Returning" Style="{StaticResource H2}" Margin="0 14 0 4" />
                                <TextBox x:Name="TxtWelcomeReturning" />
                                <TextBlock Text="Regular" Style="{StaticResource H2}" Margin="0 14 0 4" />
                                <TextBox x:Name="TxtWelcomeRegular" />
                                <TextBlock Text="Subscriber" Style="{StaticResource H2}" Margin="0 14 0 4" />
                                <TextBox x:Name="TxtWelcomeSub" />
                                <TextBlock Text="VIP" Style="{StaticResource H2}" Margin="0 14 0 4" />
                                <TextBox x:Name="TxtWelcomeVip" />
                                <TextBlock Text="Moderator" Style="{StaticResource H2}" Margin="0 14 0 4" />
                                <TextBox x:Name="TxtWelcomeMod" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Style="{StaticResource SidebarNavTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource Icon}" Data="{StaticResource IconGeo.Commands}" Margin="0 0 10 0" />
                        <TextBlock Text="Commands" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32 28" MaxWidth="900">
                        <TextBlock Text="Info commands" Style="{StaticResource H1}" />
                        <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0 0 0 18">
                            Built-ins: !uptime, !followage, !accountage, !title, !game, !so, !lurk, !unlurk,
                            !commands, !socials, !discord, !quote. Custom entries below add more, with {user} and
                            {rest} substitution.
                        </TextBlock>

                        <Border Style="{StaticResource Card}" Margin="0 0 0 14">
                            <StackPanel>
                                <TextBlock Text="!discord response" Style="{StaticResource H2}" />
                                <TextBox x:Name="TxtInfoDiscord" />
                                <TextBlock Text="!socials response" Style="{StaticResource H2}" Margin="0 14 0 4" />
                                <TextBox x:Name="TxtInfoSocials" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Custom commands" Style="{StaticResource H2}" />
                        <TextBlock Style="{StaticResource Muted}" Margin="0 0 0 8" TextWrapping="Wrap">
                            Each entry registers as !&lt;name&gt;. Use {user} for the chatter, {rest} for what they typed after the command.
                        </TextBlock>
                        <DataGrid x:Name="GrdCustomCommands" AutoGenerateColumns="False" CanUserAddRows="False"
                                  SelectionMode="Single" SelectionUnit="FullRow" Height="240">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name (no !)" Binding="{Binding Name,     UpdateSourceTrigger=PropertyChanged}" Width="160" />
                                <DataGridTextColumn Header="Response"    Binding="{Binding Response, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Orientation="Horizontal" Margin="0 10 0 0">
                            <Button Content="Add command" Style="{StaticResource SecondaryButton}" Click="BtnCustomCmdAdd_Click" Margin="0 0 8 0" />
                            <Button Content="Remove"      Style="{StaticResource SecondaryButton}" Click="BtnCustomCmdRemove_Click" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Style="{StaticResource SidebarNavTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource Icon}" Data="{StaticResource IconGeo.Quiet}" Margin="0 0 10 0" />
                        <TextBlock Text="Quiet mode" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32 28" MaxWidth="780">
                        <TextBlock Text="Quiet mode &amp; chat noise" Style="{StaticResource H1}" />
                        <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0 0 0 18">
                            Tame how chatty Loadout is. Quiet mode silences ambient posts (alerts, welcomes,
                            timers); explicit chat commands (!bolts, !uptime) still respond.
                        </TextBlock>

                        <Border Style="{StaticResource Card}" Margin="0 0 0 14">
                            <StackPanel>
                                <CheckBox x:Name="ChkQuietMode" Content="Quiet mode (silence ambient chat)" Style="{StaticResource ToggleSwitch}" />
                                <Grid Margin="0 14 0 0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Max chat per minute (channel-wide):"
                                               Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 0 12 0" />
                                    <TextBox  Grid.Column="1" x:Name="TxtMaxChatPerMin" Width="120" HorizontalAlignment="Left" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0 0 0 14">
                            <StackPanel>
                                <TextBlock Text="Per-area mute" Style="{StaticResource H2}" />
                                <TextBlock Style="{StaticResource Muted}" Margin="0 0 0 8" TextWrapping="Wrap">
                                    Untick to disable chat output for that area. Overlays, persistence, and bus events still fire.
                                </TextBlock>
                                <CheckBox x:Name="ChkAreaAlerts"   Content="Alerts to chat"        Style="{StaticResource ToggleRow}" />
                                <CheckBox x:Name="ChkAreaWelcomes" Content="Welcomes to chat"      Style="{StaticResource ToggleRow}" />
                                <CheckBox x:Name="ChkAreaInfo"     Content="Info commands to chat" Style="{StaticResource ToggleRow}" />
                                <CheckBox x:Name="ChkAreaCounters" Content="Counters to chat"      Style="{StaticResource ToggleRow}" />
