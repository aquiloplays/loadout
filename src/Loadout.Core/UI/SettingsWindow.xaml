                                <TextBox x:Name="TxtDiscordTemplate" AcceptsReturn="True" Height="80" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}" Margin="0 0 0 14">
