                                                 through the dispatcher so AlertsModule renders it like a real one.
                                                 Tag carries the kind string so the click handler knows what to fire. -->
                                            <Button Grid.Column="2" Content="Test" Style="{StaticResource SecondaryButton}"
                                                    Margin="10 0 0 0" VerticalAlignment="Top"
                                                    Tag="{Binding Kind}" Click="BtnAlertTest_Click" />
