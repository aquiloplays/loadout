                                    Viewers spend bolts to redeem rewards via chat. Action grammar:
                                    <Run FontFamily="Consolas">chat:msg</Run>,
                                    <Run FontFamily="Consolas">alert:tmpl</Run>,
                                    <Run FontFamily="Consolas">sb-action:&lt;guid&gt;</Run>,
                                    <Run FontFamily="Consolas">counter:name:+N</Run>.
                                    Placeholders: {user} {item}.
                                </TextBlock>
                                <CheckBox x:Name="ChkShopEnabled" Content="!shop / !buy enabled" Style="{StaticResource ToggleSwitch}" />
                                <Grid Margin="0 8 0 8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" /><ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="Auto" /><ColumnDefinition Width="160" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Shop command:" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 0 8 0" />
