                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" /><ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" /><ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Starting HP"         Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 0 12 0" />
