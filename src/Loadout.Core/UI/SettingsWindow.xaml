                                    <CheckBox x:Name="ChkCmdCounter" Content="Counters"      IsChecked="True" Style="{StaticResource ToggleRow}" Margin="0 0 16 0" Click="OnOverlayUrlChange" />
                                    <CheckBox x:Name="ChkCmdBolts"   Content="Bolts"         IsChecked="True" Style="{StaticResource ToggleRow}" Margin="0 0 16 0" Click="OnOverlayUrlChange" />
                                    <CheckBox x:Name="ChkCmdClip"    Content="Clip"          IsChecked="True" Style="{StaticResource ToggleRow}" Margin="0 0 16 0" Click="OnOverlayUrlChange" />
                                    <CheckBox x:Name="ChkCmdCheckIn" Content="Check-in"      IsChecked="True" Style="{StaticResource ToggleRow}" Margin="0 0 16 0" Click="OnOverlayUrlChange" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0 0 0 10">
                            <StackPanel>
                                <Grid Margin="0 0 0 8">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Style="{StaticResource Icon}" Data="{StaticResource IconGeo.Apex}" Margin="0 0 8 0" Width="14" Height="14" />
                                        <TextBlock Text="Apex" Style="{StaticResource H2}" Margin="0" />
                                    </StackPanel>
                                    <Button HorizontalAlignment="Right" Content="Test in browser"
                                            Style="{StaticResource SecondaryButton}" Tag="apex" Click="BtnOverlayOpen_Click" />
                                </Grid>
                                <Grid Margin="0 0 0 6">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtUrlApex" Grid.Column="0" IsReadOnly="True" FontFamily="Consolas" FontSize="11" />
                                    <Button  Grid.Column="1" Content="Copy" Style="{StaticResource SecondaryButton}" Tag="apex" Click="BtnOverlayCopy_Click" Margin="8 0 0 0" />
                                </Grid>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Position:" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 0 8 0" />
                                    <ComboBox x:Name="CmbApexPos" Width="160" SelectionChanged="OnOverlayUrlChange">
                                        <ComboBoxItem Content="Bottom-center" Tag="bc" IsSelected="True" />
                                        <ComboBoxItem Content="Bottom-right"  Tag="br" />
                                        <ComboBoxItem Content="Bottom-left"   Tag="bl" />
                                        <ComboBoxItem Content="Top-center"    Tag="tc" />
                                        <ComboBoxItem Content="Top-right"     Tag="tr" />
                                        <ComboBoxItem Content="Top-left"      Tag="tl" />
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- End-of-stream recap card. Subscribes to recap.posted; appears
                             for ~25s after the stream goes offline. The streamer can right-click
                             the OBS source and Save Image during that window for socials. -->
                        <Border Style="{StaticResource Card}" Margin="0 0 0 10">
                            <StackPanel>
                                <Grid Margin="0 0 0 8">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Style="{StaticResource Icon}" Data="{StaticResource IconGeo.Recap}" Margin="0 0 8 0" Width="14" Height="14" />
                                        <TextBlock Text="End-of-stream recap" Style="{StaticResource H2}" Margin="0" />
                                    </StackPanel>
                                    <Button HorizontalAlignment="Right" Content="Test in browser"
                                            Style="{StaticResource SecondaryButton}" Tag="recap" Click="BtnOverlayOpen_Click" />
                                </Grid>
                                <Grid Margin="0 0 0 6">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtUrlRecap" Grid.Column="0" IsReadOnly="True" FontFamily="Consolas" FontSize="11" />
                                    <Button  Grid.Column="1" Content="Copy" Style="{StaticResource SecondaryButton}" Tag="recap" Click="BtnOverlayCopy_Click" Margin="8 0 0 0" />
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <TextBlock Text="Align:" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 0 8 0" />
                                        <ComboBox x:Name="CmbRecapAlign" Width="140" SelectionChanged="OnOverlayUrlChange">
                                            <ComboBoxItem Content="Center" Tag="center" IsSelected="True" />
                                            <ComboBoxItem Content="Top"    Tag="top" />
                                            <ComboBoxItem Content="Bottom" Tag="bottom" />
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock Text="Visible (sec):" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 0 8 0" />
                                        <TextBox x:Name="TxtRecapDuration" Width="60" Text="25" TextChanged="OnOverlayUrlChange" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Viewer profile card (!profile @user). Sits invisible until a chatter
                             runs the command, then slides a stat card in for ~10s. -->
                        <Border Style="{StaticResource Card}" Margin="0 0 0 10">
                            <StackPanel>
                                <Grid Margin="0 0 0 8">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Style="{StaticResource Icon}" Data="{StaticResource IconGeo.Viewer}" Margin="0 0 8 0" Width="14" Height="14" />
                                        <TextBlock Text="Viewer profile (!profile)" Style="{StaticResource H2}" Margin="0" />
                                    </StackPanel>
                                    <Button HorizontalAlignment="Right" Content="Test in browser"
                                            Style="{StaticResource SecondaryButton}" Tag="viewer" Click="BtnOverlayOpen_Click" />
                                </Grid>
                                <Grid Margin="0 0 0 6">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtUrlViewer" Grid.Column="0" IsReadOnly="True" FontFamily="Consolas" FontSize="11" />
                                    <Button  Grid.Column="1" Content="Copy" Style="{StaticResource SecondaryButton}" Tag="viewer" Click="BtnOverlayCopy_Click" Margin="8 0 0 0" />
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <TextBlock Text="Position:" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 0 8 0" />
                                        <ComboBox x:Name="CmbViewerAlign" Width="140" SelectionChanged="OnOverlayUrlChange">
                                            <ComboBoxItem Content="Bottom-right" Tag="br" IsSelected="True" />
                                            <ComboBoxItem Content="Bottom-left"  Tag="bl" />
                                            <ComboBoxItem Content="Top-right"    Tag="tr" />
                                            <ComboBoxItem Content="Top-left"     Tag="tl" />
                                            <ComboBoxItem Content="Bottom-center" Tag="bc" />
                                            <ComboBoxItem Content="Top-center"    Tag="tc" />
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock Text="Visible (sec):" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 0 8 0" />
                                        <TextBox x:Name="TxtViewerDuration" Width="60" Text="10" TextChanged="OnOverlayUrlChange" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Overlay base URL" Style="{StaticResource H2}" />
                                <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0 0 0 6">
                                    Defaults to https://widget.aquilo.gg/overlays. Change if you self-host.
                                </TextBlock>
                                <TextBox x:Name="TxtOverlayBaseUrl" TextChanged="OnOverlayUrlChange" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- ============================ FOOTER ============================ -->
        <Border Grid.Row="2" Background="{StaticResource Brush.HeaderBackground}" Padding="22 10"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0 1 0 0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!-- Connection chips: live status of each integration. Solid
                     dot = connected, dim dot = configured-but-not-checked,
                     warn dot = misconfigured. Hover for details. -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="ChipTwitch" Style="{StaticResource Pill}" Margin="0 0 6 0" ToolTip="Twitch (chat + EventSub)">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="ChipTwitchDot" Width="6" Height="6" Fill="{StaticResource Brush.Border.Strong}" VerticalAlignment="Center" Margin="0 0 6 0" />
                            <TextBlock Text="Twitch" FontSize="11" Foreground="{StaticResource Brush.Fg.Muted}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border x:Name="ChipTikTok" Style="{StaticResource Pill}" Margin="0 0 6 0" ToolTip="TikTok via TikFinity">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="ChipTikTokDot" Width="6" Height="6" Fill="{StaticResource Brush.Border.Strong}" VerticalAlignment="Center" Margin="0 0 6 0" />
                            <TextBlock Text="TikTok" FontSize="11" Foreground="{StaticResource Brush.Fg.Muted}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border x:Name="ChipBus" Style="{StaticResource Pill}" Margin="0 0 6 0" ToolTip="Aquilo Bus (overlay event WebSocket)">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="ChipBusDot" Width="6" Height="6" Fill="{StaticResource Brush.Border.Strong}" VerticalAlignment="Center" Margin="0 0 6 0" />
                            <TextBlock Text="Bus" FontSize="11" Foreground="{StaticResource Brush.Fg.Muted}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border x:Name="ChipWorker" Style="{StaticResource Pill}" Margin="0 0 12 0" ToolTip="Loadout Discord bot Worker">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="ChipWorkerDot" Width="6" Height="6" Fill="{StaticResource Brush.Border.Strong}" VerticalAlignment="Center" Margin="0 0 6 0" />
                            <TextBlock Text="Worker" FontSize="11" Foreground="{StaticResource Brush.Fg.Muted}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border x:Name="PillSaved" Style="{StaticResource Pill}" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="{StaticResource Brush.Success}" VerticalAlignment="Center" Margin="0 0 6 0" />
                            <TextBlock x:Name="TxtSavedHint" FontSize="11" Foreground="{StaticResource Brush.Fg.Muted}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Close" Style="{StaticResource SecondaryButton}" Click="BtnClose_Click" Margin="0 0 8 0" />
                    <Button Content="Save changes" Style="{StaticResource PrimaryButton}" Click="BtnSave_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
