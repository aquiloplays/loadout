                                                <CheckBox IsChecked="{Binding Enabled}"
                                                          Content="{Binding Label}"
                                                          Style="{StaticResource ToggleRow}"
                                                          FontWeight="SemiBold" />
                                            </StackPanel>
                                            <TextBox  Grid.Column="1" Text="{Binding Message, UpdateSourceTrigger=PropertyChanged}"
                                                      AcceptsReturn="True" TextWrapping="Wrap" />
