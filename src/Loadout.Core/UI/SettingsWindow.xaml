                                        <DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled}" Width="40" />
                                        <DataGridTextColumn Header="Name (!buy &lt;name&gt;)" Binding="{Binding Name,    UpdateSourceTrigger=PropertyChanged}" Width="160" />
