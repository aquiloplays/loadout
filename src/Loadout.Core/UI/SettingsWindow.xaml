                                    <Path Style="{StaticResource Icon}" Data="{StaticResource IconGeo.SubRaidTrain}" Margin="0 0 8 0" Width="14" Height="14" />
                                    <TextBlock Text="Sub raid train" Style="{StaticResource H2}" Margin="0" />
