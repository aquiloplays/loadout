                                    <TextBlock Grid.Column="2" Text="Buy command:" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 0 8 0" />
                                    <TextBox  Grid.Column="3" x:Name="TxtBuyCmd" />
                                </Grid>
                                <DataGrid x:Name="GrdShop" AutoGenerateColumns="False" CanUserAddRows="False"
                                          SelectionMode="Single" SelectionUnit="FullRow" Height="200">
