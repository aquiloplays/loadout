                    </TextBlock>
                    <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0 0 0 12">
                        <CheckBox x:Name="ChkGameProfilesEnabled" Content="Per-game profile overrides enabled" Style="{StaticResource ToggleSwitch}" />
                    </Border>
                    <DataGrid Grid.Row="3" x:Name="GrdGameProfiles" AutoGenerateColumns="False" CanUserAddRows="False"
