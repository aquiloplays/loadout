                                <TextBlock Text="Discord template (placeholders: {user} {url})" Style="{StaticResource Muted}" Margin="0 12 0 4" />
                                <TextBox x:Name="TxtClipDiscordTemplate" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

