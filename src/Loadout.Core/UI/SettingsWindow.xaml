                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32 28" MaxWidth="780">
                        <TextBlock Text="VIP rotation" Style="{StaticResource H1}" />
                        <TextBlock Style="{StaticResource Muted}" Margin="0 0 0 18" TextWrapping="Wrap">
                            Promotes the most active non-VIP chatters every cycle, and demotes the longest-held
                            VIP slots to make room. Exempt handles are never auto-demoted (use this for friends,
                            family, supporters who hold permanent VIP).
                        </TextBlock>
                        <Border Style="{StaticResource Card}" Margin="0 0 0 14">
                            <StackPanel>
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="160" /></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Cycle interval (days)"  Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 6 12 0" />
                                    <TextBox  Grid.Row="0" Grid.Column="1" x:Name="TxtVipInterval" Margin="0 4 0 0" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Promotions per cycle"   Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 6 12 0" />
                                    <TextBox  Grid.Row="1" Grid.Column="1" x:Name="TxtVipPerCycle" Margin="0 4 0 0" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Min messages to qualify" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 6 12 0" />
                                    <TextBox  Grid.Row="2" Grid.Column="1" x:Name="TxtVipMinMsg" Margin="0 4 0 0" />
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}" Margin="0 0 0 14">
                            <StackPanel>
                                <TextBlock Text="Exempt handles (one per line)" Style="{StaticResource H2}" />
                                <TextBox x:Name="TxtVipExempt" AcceptsReturn="True" Height="120" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Discord webhook (optional)" Style="{StaticResource H2}" />
                                <TextBox x:Name="TxtVipDiscord" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Style="{StaticResource SidebarNavTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource Icon}" Data="{StaticResource IconGeo.Clips}" Margin="0 0 10 0" />
                        <TextBlock Text="Clips" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32 28" MaxWidth="900">
                        <TextBlock Text="Clip on demand (!clip)" Style="{StaticResource H1}" />
                        <TextBlock Style="{StaticResource Muted}" Margin="0 0 0 18" TextWrapping="Wrap">
                            Lets viewers create a Twitch clip from chat. The URL is posted back, optionally
                            mirrored to a Discord webhook, and the clipper can earn a Bolts thank-you.
                            Twitch-only - the command politely refuses on YouTube/Kick/TikTok.
                        </TextBlock>

                        <Border Style="{StaticResource Card}" Margin="0 0 0 14">
                            <StackPanel>
                                <CheckBox x:Name="ChkClipsEnabled" Content="!clip enabled" Style="{StaticResource ToggleSwitch}" />
                                <TextBlock Text="Command (default !clip)" Style="{StaticResource H2}" Margin="0 14 0 4" />
                                <TextBox x:Name="TxtClipCommand" Width="220" HorizontalAlignment="Left" />
                                <TextBlock Text="Allowed roles (CSV)" Style="{StaticResource H2}" Margin="0 14 0 4" />
                                <TextBlock Style="{StaticResource Faint}" Margin="0 0 0 4">
                                    Examples: sub,vip,mod,broadcaster · everyone · vip,mod
                                </TextBlock>
                                <TextBox x:Name="TxtClipRoles" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0 0 0 14">
                            <StackPanel>
                                <TextBlock Text="Cooldowns (seconds)" Style="{StaticResource H2}" />
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" /><ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" /><ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Per-user (non-mods)" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 6 12 0" />
                                    <TextBox  Grid.Row="0" Grid.Column="1" x:Name="TxtClipUserCd" Margin="0 4 12 0" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Mods + broadcaster" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 6 12 0" />
                                    <TextBox  Grid.Row="0" Grid.Column="3" x:Name="TxtClipModCd"  Margin="0 4 0 0" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Channel-wide"      Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 6 12 0" />
                                    <TextBox  Grid.Row="1" Grid.Column="1" x:Name="TxtClipChannelCd" Margin="0 4 12 0" />
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Bolts award per clip" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 6 12 0" />
                                    <TextBox  Grid.Row="1" Grid.Column="3" x:Name="TxtClipBoltsAward" Margin="0 4 0 0" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0 0 0 14">
