                                <CheckBox x:Name="ChkDiscordAutoEdit" Content="Auto-edit message on title/category change" Style="{StaticResource ToggleSwitch}" />
                                <CheckBox x:Name="ChkDiscordArchive"  Content="Archive (vs delete) when stream ends"        Style="{StaticResource ToggleSwitch}" />
