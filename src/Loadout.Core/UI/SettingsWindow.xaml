                                        <ColumnDefinition Width="*" /><ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" /><ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Sub"                 Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 6 12 0" />
                                    <TextBox  Grid.Row="0" Grid.Column="1" x:Name="TxtApexDmgSub"     Margin="0 4 12 0" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Resub"              Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 6 12 0" />
                                    <TextBox  Grid.Row="0" Grid.Column="3" x:Name="TxtApexDmgResub"   Margin="0 4 0 0" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Gift sub (× count)" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 6 12 0" />
                                    <TextBox  Grid.Row="1" Grid.Column="1" x:Name="TxtApexDmgGift"    Margin="0 4 12 0" />
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Per 100 bits"        Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 6 12 0" />
                                    <TextBox  Grid.Row="1" Grid.Column="3" x:Name="TxtApexDmgBits"    Margin="0 4 0 0" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Per TikTok coin"    Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 6 12 0" />
                                    <TextBox  Grid.Row="2" Grid.Column="1" x:Name="TxtApexDmgTikTok"  Margin="0 4 12 0" />
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Per CC coin"        Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 6 12 0" />
                                    <TextBox  Grid.Row="2" Grid.Column="3" x:Name="TxtApexDmgCcCoin"  Margin="0 4 0 0" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Per Bolts spent"    Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 6 12 0" />
                                    <TextBox  Grid.Row="3" Grid.Column="1" x:Name="TxtApexDmgBolts"   Margin="0 4 12 0" />
                                    <TextBlock Grid.Row="3" Grid.Column="2" Text="Per channel-pt redeem" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 6 12 0" />
                                    <TextBox  Grid.Row="3" Grid.Column="3" x:Name="TxtApexDmgChanPt"  Margin="0 4 0 0" />
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Per check-in"       Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 6 12 0" />
                                    <TextBox  Grid.Row="4" Grid.Column="1" x:Name="TxtApexDmgCheckIn" Margin="0 4 12 0" />
                                    <TextBlock Grid.Row="4" Grid.Column="2" Text="Per raid viewer"     Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 6 12 0" />
                                    <TextBox  Grid.Row="4" Grid.Column="3" x:Name="TxtApexDmgRaid"    Margin="0 4 0 0" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Behavior" Style="{StaticResource H2}" />
                                <CheckBox x:Name="ChkApexAutoCrown"  Content="Auto-crown the finisher"          Style="{StaticResource ToggleSwitch}" />
                                <CheckBox x:Name="ChkApexSelfImm"    Content="Champion self-immunity"           Style="{StaticResource ToggleSwitch}" />
                                <CheckBox x:Name="ChkApexIncBcaster" Content="Broadcaster can hold the crown"   Style="{StaticResource ToggleSwitch}" />
                                <CheckBox x:Name="ChkApexAnnounce"   Content="Announce crown changes in chat"   Style="{StaticResource ToggleSwitch}" />
                                <TextBlock Text="Discord webhook (optional)" Style="{StaticResource H2}" Margin="0 12 0 4" />
                                <TextBox x:Name="TxtApexDiscord" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============ LIVE OPS ============ -->
            <TabItem Style="{StaticResource SidebarNavSectionHeader}">
                <TabItem.Header><TextBlock Text="LIVE OPS" Style="{StaticResource SidebarGroupLabel}" /></TabItem.Header>
            </TabItem>

            <TabItem Style="{StaticResource SidebarNavTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource Icon}" Data="{StaticResource IconGeo.HateRaid}" Margin="0 0 10 0" />
                        <TextBlock Text="Hate raid" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32 28" MaxWidth="780">
                        <TextBlock Text="Hate-raid detector" Style="{StaticResource H1}" />
                        <TextBlock Style="{StaticResource Muted}" Margin="0 0 0 18" TextWrapping="Wrap">
                            Watches for a sudden burst of new accounts joining + chatting. When the threshold is
                            crossed, Loadout enables emote-only mode and follower-only mode, then DMs you the
                            timeline so you can review later. Manual override commands work in chat as a backstop.
                        </TextBlock>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
