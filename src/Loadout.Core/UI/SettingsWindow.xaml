                                    <TextBox  Grid.Column="3" x:Name="TxtApexChatThr"   Margin="0 4 0 0" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0 0 0 14">
