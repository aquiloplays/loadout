                                    <TextBox  Grid.Row="1" Grid.Column="1" x:Name="TxtHateWindow" Margin="0 4 0 0" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Min new-account chats to trigger" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 6 12 0" />
                                    <TextBox  Grid.Row="2" Grid.Column="1" x:Name="TxtHateMinAccounts" Margin="0 4 0 0" />
