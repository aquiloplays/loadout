                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Style="{StaticResource SidebarNavTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource Icon}" Data="{StaticResource IconGeo.DiscordBot}" Margin="0 0 10 0" />
                        <TextBlock Text="Discord bot" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32 28" MaxWidth="900">
                        <TextBlock Text="Off-stream Discord bot" Style="{StaticResource H1}" />
                        <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0 0 0 18">
                            Lets viewers earn + spend Bolts in your Discord server while you're offline. Slash
                            commands: <Run FontFamily="Consolas">/balance /gift /leaderboard /daily /coinflip /dice /link /help</Run>.
                            Powered by a Cloudflare Worker so it stays up 24/7 - your PC doesn't need to be on.
                        </TextBlock>

                        <Border Style="{StaticResource Card}" Margin="0 0 0 14">
                            <StackPanel>
                                <CheckBox x:Name="ChkDiscordBotEnabled" Content="Enable Discord bot sync" Style="{StaticResource ToggleSwitch}" />
                                <TextBlock Style="{StaticResource Muted}" Margin="0 8 0 0" TextWrapping="Wrap">
                                    Three-step setup. No Discord developer account needed.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Step 1: invite the shared bot -->
                        <Border Style="{StaticResource Card}" Margin="0 0 0 14">
                            <StackPanel>
                                <TextBlock Text="① Invite the Loadout Bot to your server" Style="{StaticResource H2}" />
                                <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0 0 0 8">
                                    Click the button below; Discord will ask which server you want to add the bot to.
                                    You need <Bold>Manage Server</Bold> permission on that server.
                                </TextBlock>
                                <Button Content="Open invite link in browser" Style="{StaticResource SecondaryButton}"
                                        HorizontalAlignment="Left" Click="BtnDcbOpenInvite_Click" />
                            </StackPanel>
                        </Border>

                        <!-- Step 2: get + use a claim code -->
                        <Border Style="{StaticResource Card}" Margin="0 0 0 14">
                            <StackPanel>
                                <TextBlock Text="② Claim your server" Style="{StaticResource H2}" />
                                <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0 0 0 8">
                                    Generate a code, then in your Discord server type
                                    <Run FontFamily="Consolas">/loadout-claim CODE</Run>.
                                    Loadout polls the worker and finishes setup automatically once you do.
                                </TextBlock>
                                <Grid Margin="0 0 0 4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox  Grid.Column="0" x:Name="TxtDcbClaimCode" IsReadOnly="True" FontFamily="Consolas" FontSize="18" FontWeight="SemiBold" />
                                    <Button   Grid.Column="1" Content="Get my code" Style="{StaticResource PrimaryButton}"
                                              Margin="8 0 0 0" Click="BtnDcbMintCode_Click" />
                                    <Button   Grid.Column="2" Content="Copy"        Style="{StaticResource SecondaryButton}"
                                              Margin="8 0 0 0" Click="BtnDcbCopyCode_Click" />
                                </Grid>
                                <TextBlock x:Name="TxtDcbClaimHint" Style="{StaticResource Muted}" Margin="0 6 0 0" TextWrapping="Wrap"
                                           Text="Codes are valid for 10 minutes." />
                            </StackPanel>
                        </Border>

                        <!-- Step 3: sync -->
                        <Border Style="{StaticResource Card}" Margin="0 0 0 14">
                            <StackPanel>
                                <TextBlock Text="③ Sync wallet state" Style="{StaticResource H2}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" /><ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="Auto" /><ColumnDefinition Width="160" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Auto-sync (min):" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 0 8 0" />
                                    <TextBox  Grid.Column="1" x:Name="TxtDcbAutoSync" Margin="0 0 14 0" />
                                    <TextBlock Grid.Column="2" Text="Mode:" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 0 8 0" />
                                    <ComboBox Grid.Column="3" x:Name="CmbDcbSyncMode">
                                        <ComboBoxItem Content="Merge (max balance)" Tag="merge" IsSelected="True" />
                                        <ComboBoxItem Content="Push local up"       Tag="push" />
                                        <ComboBoxItem Content="Pull remote down"    Tag="pull" />
                                    </ComboBox>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0 14 0 0">
                                    <Button Content="Pull now"  Style="{StaticResource SecondaryButton}" Click="BtnDcbPull_Click"  Margin="0 0 8 0" />
                                    <Button Content="Push now"  Style="{StaticResource SecondaryButton}" Click="BtnDcbPush_Click"  Margin="0 0 8 0" />
                                    <Button Content="Unlink server" Style="{StaticResource SecondaryButton}" Click="BtnDcbUnlink_Click" />
                                </StackPanel>
                                <TextBlock x:Name="TxtDcbStatus" Style="{StaticResource Muted}" Margin="0 10 0 0" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Advanced" Style="{StaticResource H2}" />
                                <TextBlock Style="{StaticResource Muted}" Margin="0 0 0 4">
                                    Worker URL — defaults to shared aquilo.gg worker. Override only if you self-host.
                                </TextBlock>
                                <TextBox x:Name="TxtDcbWorkerUrl" />
                                <TextBlock Text="Bound Discord guild" Style="{StaticResource Muted}" Margin="0 12 0 4" />
                                <TextBox x:Name="TxtDcbGuildId" IsReadOnly="True" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Style="{StaticResource SidebarNavTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource BrandIcon}" Data="{StaticResource IconGeo.Twitter}" Fill="{DynamicResource Brush.Fg.Primary}" Margin="0 0 10 0" />
                        <TextBlock Text="Twitter / X" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32 28" MaxWidth="780">
                        <TextBlock Text="Twitter / X live status" Style="{StaticResource H1}" />
                        <TextBlock Style="{StaticResource Muted}" Margin="0 0 0 18" TextWrapping="Wrap">
                            X charges $100/mo for write access via their official API. We dodge that with a
                            generic webhook: Loadout posts a JSON payload to a URL you configure (Zapier,
                            Make, IFTTT, n8n, your own Cloudflare Worker), and that endpoint posts the tweet.
                            You only pay whatever your automation tool costs.
                        </TextBlock>
                        <Border Style="{StaticResource Card}" Margin="0 0 0 14">
                            <StackPanel>
                                <TextBlock Text="Webhook URL" Style="{StaticResource H2}" />
                                <TextBox x:Name="TxtTwitterWebhook" />
                                <TextBlock Text="Live template" Style="{StaticResource H2}" Margin="0 14 0 4" />
                                <TextBox x:Name="TxtTwitterLiveTemplate" AcceptsReturn="True" Height="80" TextWrapping="Wrap" />
                                <TextBlock Text="Offline template" Style="{StaticResource H2}" Margin="0 14 0 4" />
                                <TextBox x:Name="TxtTwitterOfflineTemplate" AcceptsReturn="True" Height="60" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <CheckBox x:Name="ChkTwitterPostOnUpdate" Content="Also post when title/category changes mid-stream" Style="{StaticResource ToggleSwitch}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Style="{StaticResource SidebarNavTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource Icon}" Data="{StaticResource IconGeo.Webhooks}" Margin="0 0 10 0" />
                        <TextBlock Text="Webhooks" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="32 28">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Webhook inbox" Style="{StaticResource H1}" />
                    <TextBlock Grid.Row="1" Style="{StaticResource Muted}" Margin="0 0 0 14" TextWrapping="Wrap">
                        Loadout listens on a local port for incoming HTTP webhooks (Ko-fi, Streamlabs,
                        Throne, custom workflows). Each path maps to a Streamer.bot action that runs when
                        a hit comes in. Add the path to your sender, paste the SB action ID below.
                    </TextBlock>

                    <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0 0 0 14">
                        <StackPanel>
                            <CheckBox x:Name="ChkWebhookEnabled" Content="Inbox listener enabled" Style="{StaticResource ToggleSwitch}" />
                            <Grid Margin="0 12 0 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Port:"          Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 0 8 0" />
                                <TextBox  Grid.Column="1" x:Name="TxtWebhookPort"   Width="120" HorizontalAlignment="Left" Margin="0 0 14 0" />
                                <TextBlock Grid.Column="2" Text="Shared secret:" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 0 8 0" />
                                <TextBox  Grid.Column="3" x:Name="TxtWebhookSecret" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="3" x:Name="GrdWebhooks" AutoGenerateColumns="False" CanUserAddRows="False"
                              SelectionMode="Single" SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Path"        Binding="{Binding Path,        UpdateSourceTrigger=PropertyChanged}" Width="200" />
                            <DataGridTextColumn Header="SB action id" Binding="{Binding SbActionId, UpdateSourceTrigger=PropertyChanged}" Width="280" />
                            <DataGridTextColumn Header="Description" Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0 12 0 0">
                        <Button Content="Add mapping" Style="{StaticResource SecondaryButton}" Click="BtnWebhookAdd_Click" Margin="0 0 8 0" />
                        <Button Content="Remove"      Style="{StaticResource SecondaryButton}" Click="BtnWebhookRemove_Click" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ============ INTEGRATIONS (channel points) ============ -->
            <TabItem Style="{StaticResource SidebarNavTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource Icon}" Data="{StaticResource IconGeo.ChannelPoints}" Margin="0 0 10 0" />
                        <TextBlock Text="Channel points" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="32 28">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Channel-point reward → action" Style="{StaticResource H1}" />
                    <TextBlock Grid.Row="1" Style="{StaticResource Muted}" Margin="0 0 0 14" TextWrapping="Wrap">
                        Map a Twitch channel-point reward to an action. Action format:
                        <Run FontFamily="Consolas">chat:&lt;msg&gt;</Run>,
                        <Run FontFamily="Consolas">bolts:+250</Run>,
                        <Run FontFamily="Consolas">counter:deaths:+1</Run>,
                        <Run FontFamily="Consolas">sb-action:&lt;guid&gt;</Run>,
                        <Run FontFamily="Consolas">alert:&lt;template&gt;</Run>.
                        Substitutions: {user} {reward}.
                    </TextBlock>
                    <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0 0 0 12">
                        <CheckBox x:Name="ChkChannelPointsEnabled" Content="Channel-point integration enabled" Style="{StaticResource ToggleSwitch}" />
                    </Border>
                    <DataGrid Grid.Row="3" x:Name="GrdChannelPoints" AutoGenerateColumns="False" CanUserAddRows="False"
                              SelectionMode="Single" SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled}" Width="40" />
                            <DataGridTextColumn Header="Reward name (Twitch)" Binding="{Binding RewardName, UpdateSourceTrigger=PropertyChanged}" Width="220" />
                            <DataGridTextColumn Header="Action"               Binding="{Binding Action,     UpdateSourceTrigger=PropertyChanged}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0 12 0 0">
                        <Button Content="Add mapping" Style="{StaticResource SecondaryButton}" Click="BtnChannelPointAdd_Click"    Margin="0 0 8 0" />
                        <Button Content="Remove"      Style="{StaticResource SecondaryButton}" Click="BtnChannelPointRemove_Click" />
                    </StackPanel>
                </Grid>
