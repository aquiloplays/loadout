<Window x:Class="Loadout.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loadout Settings"
        Width="940" Height="680"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="Window_Loaded"
        Opacity="0">
    <Window.RenderTransform>
        <TranslateTransform Y="12" />
    </Window.RenderTransform>
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Loadout;component/UI/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Brush.Bg.Surface}" Padding="20 14"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0 0 0 1">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Loadout" Style="{StaticResource H1}" />
                    <TextBlock x:Name="TxtVersionLine" Text="Version 0.1.0 — checking for updates…" Style="{StaticResource Muted}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Re-run onboarding" Style="{StaticResource SecondaryButton}"
                            Margin="0 0 8 0" Click="BtnReonboard_Click" />
                    <Button Content="Check for updates" Style="{StaticResource SecondaryButton}"
                            Click="BtnCheckUpdate_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Background="{StaticResource Brush.Bg.Primary}"
                    BorderThickness="0" Margin="8 8 8 0">

            <!-- General -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="Broadcaster" Style="{StaticResource H2}" />
                        <TextBox x:Name="TxtBroadcaster" Width="320" HorizontalAlignment="Left" />

                        <TextBlock Text="Platforms" Style="{StaticResource H2}" Margin="0 24 0 8" />
                        <CheckBox x:Name="ChkTwitch"  Content="Twitch"   Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ChkTikTok"  Content="TikTok"   Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ChkYouTube" Content="YouTube"  Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ChkKick"    Content="Kick"     Style="{StaticResource ToggleRow}" />

                        <TextBlock Text="Update channel" Style="{StaticResource H2}" Margin="0 24 0 8" />
                        <ComboBox x:Name="CmbChannel" Width="200" HorizontalAlignment="Left">
                            <ComboBoxItem Content="Stable" Tag="stable" />
                            <ComboBoxItem Content="Beta"   Tag="beta" />
                        </ComboBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Modules -->
            <TabItem Header="Modules">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="Toggle modules on/off" Style="{StaticResource H2}" />
                        <CheckBox x:Name="ModInfo"     Content="Info commands" Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ModWelcomes" Content="Context-aware welcomes" Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ModLoyalty"  Content="Loyalty wallet" Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ModAlerts"   Content="Alerts" Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ModTimers"   Content="Auto-timed messages" Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ModAi"       Content="AI personalized shoutouts" Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ModHype"     Content="TikTok hype train" Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ModRecap"    Content="Stream recap" Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ModDiscord"  Content="Discord live status" Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ModWebhook"  Content="Webhook inbox" Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ModMod"      Content="Moderation" Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ModFun"      Content="Fun commands" Style="{StaticResource ToggleRow}" />
                        <CheckBox x:Name="ModGoals"    Content="Goals" Style="{StaticResource ToggleRow}" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Alerts (placeholder for full editor in Phase 2) -->
            <TabItem Header="Alerts">
                <StackPanel Margin="20">
                    <TextBlock Text="Alert templates" Style="{StaticResource H2}" />
                    <TextBlock Style="{StaticResource Muted}" Margin="0 0 0 12" TextWrapping="Wrap">
                        Placeholders: {user} {tier} {months} {gifter} {count} {bits} {viewers} {amount} {gift} {coins}
                    </TextBlock>
                    <TextBlock Text="Phase 2 — full per-alert editor coming. Defaults are sensible; tweak in settings.json for now." Style="{StaticResource Muted}" />
                </StackPanel>
            </TabItem>

            <!-- Timers -->
            <TabItem Header="Timers">
                <StackPanel Margin="20">
                    <TextBlock Text="Auto-timed messages" Style="{StaticResource H2}" />
                    <TextBlock Style="{StaticResource Muted}" Margin="0 0 0 12" TextWrapping="Wrap">
                        Phase 2 — DataGrid editor with name/message/interval/activity gate/platforms.
                        Edit settings.json for now to add timers; loaded automatically.
                    </TextBlock>
                </StackPanel>
            </TabItem>

            <!-- Counters -->
            <TabItem Header="Counters">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Custom counters" Style="{StaticResource H1}" />
                    <TextBlock Grid.Row="1" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0 0 0 12">
                        Each counter responds to !&lt;name&gt; in chat. !&lt;name&gt; +1 / -2 / set N / reset.
                        Free tier shows the first 3; Plus removes the cap. Counters publish to the Aquilo Bus
                        the moment they change, so overlays update live.
                    </TextBlock>

                    <DataGrid Grid.Row="2" x:Name="GrdCounters" AutoGenerateColumns="False" CanUserAddRows="False"
                              Background="{StaticResource Brush.Bg.Surface}"
                              Foreground="{StaticResource Brush.Fg.Primary}"
                              BorderBrush="{StaticResource Brush.Border}"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              RowBackground="Transparent" AlternatingRowBackground="#1F1F23"
                              SelectionMode="Single" SelectionUnit="FullRow"
                              RowHeight="34">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name (chat token)"      Binding="{Binding Name,           UpdateSourceTrigger=PropertyChanged}" Width="160" />
                            <DataGridTextColumn Header="Display"                Binding="{Binding Display,        UpdateSourceTrigger=PropertyChanged}" Width="160" />
                            <DataGridTextColumn Header="Value"                  Binding="{Binding Value,          UpdateSourceTrigger=PropertyChanged}" Width="80" />
                            <DataGridTextColumn Header="Modify roles (csv)"     Binding="{Binding ModifyRoles,    UpdateSourceTrigger=PropertyChanged}" Width="180" />
                            <DataGridTextColumn Header="Response template"      Binding="{Binding ResponseTemplate,UpdateSourceTrigger=PropertyChanged}" Width="*" />
                            <DataGridCheckBoxColumn Header="Reset/stream"       Binding="{Binding ResetEachStream}" Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0 12 0 0">
                        <Button Content="Add counter"  Style="{StaticResource SecondaryButton}" Click="BtnCounterAdd_Click"  Margin="0 0 8 0" />
                        <Button Content="Remove"       Style="{StaticResource SecondaryButton}" Click="BtnCounterRemove_Click" Margin="0 0 8 0" />
                        <Button Content="-1"           Style="{StaticResource SecondaryButton}" Click="BtnCounterMinus_Click"  Margin="0 0 8 0" />
                        <Button Content="+1"           Style="{StaticResource PrimaryButton}"   Click="BtnCounterPlus_Click"   Margin="0 0 8 0" />
                        <Button Content="Reset to 0"   Style="{StaticResource SecondaryButton}" Click="BtnCounterReset_Click" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Check-In -->
            <TabItem Header="Check-In">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="Daily Check-In" Style="{StaticResource H1}" />
                        <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0 0 0 12">
                            On Twitch, redeeming a Channel Point reward with the configured title fires the overlay.
                            On YouTube / Kick / TikTok the chat command does the same.
                        </TextBlock>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Twitch reward title" Style="{StaticResource H2}" />
                                <TextBox x:Name="TxtCheckInReward" />
                                <TextBlock Text="Cross-platform command" Style="{StaticResource H2}" Margin="0 12 0 4" />
                                <TextBox x:Name="TxtCheckInCommand" />
                                <TextBlock Text="Per-user cooldown (hours)" Style="{StaticResource H2}" Margin="0 12 0 4" />
                                <TextBox x:Name="TxtCheckInCooldown" Width="120" HorizontalAlignment="Left" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0 16 0 0">
                            <StackPanel>
                                <TextBlock Text="Animation theme" Style="{StaticResource H2}" />
                                <ComboBox x:Name="CmbCheckInTheme" Width="220" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="Shimmer (default)" Tag="shimmer" />
                                    <ComboBoxItem Content="Bounce"            Tag="bounce" />
                                    <ComboBoxItem Content="Glow"              Tag="glow" />
                                    <ComboBoxItem Content="Minimal"           Tag="minimal" />
                                </ComboBox>
                                <TextBlock Text="Flairs" Style="{StaticResource H2}" Margin="0 12 0 4" />
                                <CheckBox x:Name="ChkSubFlair"     Content="Show sub-tier flair"        Style="{StaticResource ToggleRow}" />
                                <CheckBox x:Name="ChkVipModFlair"  Content="Show VIP / mod flair"       Style="{StaticResource ToggleRow}" />
                                <CheckBox x:Name="ChkPatreonFlair" Content="Show Patreon supporter flair (Tier 3)" Style="{StaticResource ToggleRow}" />
                                <TextBlock Text="Stat rotation interval (seconds)" Style="{StaticResource H2}" Margin="0 12 0 4" />
                                <TextBox x:Name="TxtCheckInRotateSec" Width="120" HorizontalAlignment="Left" />
                                <TextBlock Text="Stats to rotate (comma-separated)" Style="{StaticResource H2}" Margin="0 12 0 4" />
                                <TextBox x:Name="TxtCheckInStats" />
                                <TextBlock Style="{StaticResource Muted}" Margin="0 4 0 0" TextWrapping="Wrap">
                                    Built-ins: uptime, viewers, followers, subsThisStream, topChatter. Custom counters: counter:&lt;name&gt;
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0 16 0 0">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="Patreon supporters (local list)" Style="{StaticResource H2}" />
                                    <TextBlock Style="{StaticResource Muted}" HorizontalAlignment="Right"
                                               Text="Phase 2: viewers self-claim at aquilo.gg/link" />
                                </Grid>
                                <DataGrid x:Name="GrdSupporters" AutoGenerateColumns="False" CanUserAddRows="False"
                                          Background="{StaticResource Brush.Bg.Surface2}"
                                          Foreground="{StaticResource Brush.Fg.Primary}"
                                          BorderBrush="{StaticResource Brush.Border}"
                                          GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                          RowBackground="Transparent" AlternatingRowBackground="#1F1F23"
                                          SelectionMode="Single" Height="160" Margin="0 8 0 0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Platform" Binding="{Binding Platform, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                                        <DataGridTextColumn Header="Handle"   Binding="{Binding Handle,   UpdateSourceTrigger=PropertyChanged}" Width="200" />
                                        <DataGridTextColumn Header="Tier"     Binding="{Binding Tier,     UpdateSourceTrigger=PropertyChanged}" Width="120" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Orientation="Horizontal" Margin="0 8 0 0">
                                    <Button Content="Add supporter" Style="{StaticResource SecondaryButton}" Click="BtnSupporterAdd_Click"    Margin="0 0 8 0" />
                                    <Button Content="Remove"        Style="{StaticResource SecondaryButton}" Click="BtnSupporterRemove_Click" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0 16 0 0">
                            <StackPanel>
                                <TextBlock Text="Test overlay" Style="{StaticResource H2}" />
                                <TextBlock Style="{StaticResource Muted}" Margin="0 0 0 8" TextWrapping="Wrap">
                                    Fires a fake check-in event onto the Aquilo Bus. Open
                                    https://aquilo.gg/overlays/check-in (or your local copy) in OBS first.
                                </TextBlock>
                                <Button Content="Fire test check-in" Style="{StaticResource PrimaryButton}"
                                        Click="BtnCheckInTest_Click" HorizontalAlignment="Left" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Discord -->
            <TabItem Header="Discord">
                <StackPanel Margin="20">
                    <TextBlock Text="Live-status webhook" Style="{StaticResource H2}" />
                    <TextBox x:Name="TxtDiscordWebhook" />
                    <TextBlock Text="Recap webhook" Style="{StaticResource H2}" Margin="0 16 0 4" />
                    <TextBox x:Name="TxtDiscordRecap" />
                    <TextBlock Text="Go-live template" Style="{StaticResource H2}" Margin="0 16 0 4" />
                    <TextBox x:Name="TxtDiscordTemplate" AcceptsReturn="True" Height="80" TextWrapping="Wrap" />
                </StackPanel>
            </TabItem>

            <!-- AI -->
            <TabItem Header="AI">
                <StackPanel Margin="20">
                    <TextBlock Text="Provider" Style="{StaticResource H2}" />
                    <ComboBox x:Name="CmbAiProvider" Width="240" HorizontalAlignment="Left">
                        <ComboBoxItem Content="Anthropic Claude" Tag="anthropic" />
                        <ComboBoxItem Content="OpenAI" Tag="openai" />
                        <ComboBoxItem Content="None" Tag="none" />
                    </ComboBox>
                    <TextBlock Text="API key" Style="{StaticResource H2}" Margin="0 16 0 4" />
                    <TextBox x:Name="TxtAiKey" />
                    <TextBlock Text="Model" Style="{StaticResource H2}" Margin="0 16 0 4" />
                    <TextBox x:Name="TxtAiModel" Width="320" HorizontalAlignment="Left" />
                </StackPanel>
            </TabItem>

            <!-- Webhooks -->
            <TabItem Header="Webhooks">
                <StackPanel Margin="20">
                    <TextBlock Text="Inbox port" Style="{StaticResource H2}" />
                    <TextBox x:Name="TxtWebhookPort" Width="120" HorizontalAlignment="Left" />
                    <TextBlock Text="Shared secret" Style="{StaticResource H2}" Margin="0 16 0 4" />
                    <TextBox x:Name="TxtWebhookSecret" />
                    <TextBlock Style="{StaticResource Muted}" Margin="0 12 0 0" TextWrapping="Wrap">
                        Phase 2 — full path-to-action mapping table here.
                    </TextBlock>
                </StackPanel>
            </TabItem>

            <!-- Patreon -->
            <TabItem Header="Patreon">
                <StackPanel Margin="20">
                    <TextBlock Text="Loadout Plus / Pro" Style="{StaticResource H1}" />
                    <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0 0 0 16">
                        Loadout's free tier covers info commands, Twitch alerts, basic welcomes, and 3 timed messages.
                        Tier 2 ($6) unlocks multi-platform, unlimited timers, Discord live status, webhook inbox, and stream recap.
                        Tier 3 ($10) adds AI shoutouts, hate-raid detection, TikTok hype train, smart auto-clipper,
                        and the cross-platform loyalty wallet.
                    </TextBlock>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Status" Style="{StaticResource H2}" />
                            <TextBlock x:Name="TxtPatreonTier" Style="{StaticResource Muted}" />
                            <TextBlock x:Name="TxtPatreonName" Style="{StaticResource Muted}" Margin="0 4 0 0" />
                            <TextBlock x:Name="TxtPatreonReason" Style="{StaticResource Muted}" Margin="0 4 0 0" />
                            <StackPanel Orientation="Horizontal" Margin="0 12 0 0">
                                <Button x:Name="BtnPatreonConnect" Content="Connect Patreon"
                                        Style="{StaticResource PrimaryButton}" Click="BtnPatreonConnect_Click"
                                        Margin="0 0 8 0" />
                                <Button x:Name="BtnPatreonRefresh" Content="Re-check tier"
                                        Style="{StaticResource SecondaryButton}" Click="BtnPatreonRefresh_Click"
                                        Margin="0 0 8 0" />
                                <Button x:Name="BtnPatreonSignOut" Content="Sign out"
                                        Style="{StaticResource SecondaryButton}" Click="BtnPatreonSignOut_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="What unlocks" Style="{StaticResource H2}" Margin="0 24 0 8" />
                    <ItemsControl x:Name="LstFeatures" />
                </StackPanel>
            </TabItem>

            <!-- Identity -->
            <TabItem Header="Identity">
                <StackPanel Margin="20">
                    <TextBlock Text="Pending link requests" Style="{StaticResource H2}" />
                    <TextBlock x:Name="TxtPendingLinks" Style="{StaticResource Muted}" Margin="0 4 0 0" />
                    <TextBlock Style="{StaticResource Muted}" Margin="0 16 0 0" TextWrapping="Wrap">
                        Viewers run <Bold>!link &lt;platform&gt; &lt;username&gt;</Bold>; you approve here or with mod commands.
                    </TextBlock>
                </StackPanel>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="{StaticResource Brush.Bg.Surface}" Padding="20 12"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0 1 0 0">
            <Grid>
                <TextBlock x:Name="TxtSavedHint" Style="{StaticResource Muted}" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Close" Style="{StaticResource SecondaryButton}" Click="BtnClose_Click"
                            Margin="0 0 8 0" />
                    <Button Content="Save" Style="{StaticResource PrimaryButton}" Click="BtnSave_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
