                                    <TextBox  Grid.Row="2" Grid.Column="3" x:Name="TxtBoltsCcDivisor"    Margin="0 4 0 0" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Per daily check-in"    Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 6 12 0" />
                                    <TextBox  Grid.Row="3" Grid.Column="1" x:Name="TxtBoltsCheckIn"      Margin="0 4 12 0" />
                                    <TextBlock Grid.Row="3" Grid.Column="2" Text="Sub-anniv bonus base"  Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 6 12 0" />
                                    <TextBox  Grid.Row="3" Grid.Column="3" x:Name="TxtBoltsAnnivBase"    Margin="0 4 0 0" />
