                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource BrandIcon}" Data="{StaticResource IconGeo.Discord}" Fill="#5865F2" Margin="0 0 10 0" />
                        <TextBlock Text="Discord" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
