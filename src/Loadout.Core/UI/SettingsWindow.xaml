                        <Button Content="Add timer" Style="{StaticResource SecondaryButton}" Click="BtnTimerAdd_Click"    Margin="0 0 8 0" />
                        <Button Content="Remove"    Style="{StaticResource SecondaryButton}" Click="BtnTimerRemove_Click" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Style="{StaticResource SidebarNavTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource Icon}" Data="{StaticResource IconGeo.Goals}" Margin="0 0 10 0" />
                        <TextBlock Text="Goals" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
