                                <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TxtTimersMinWin"   Margin="0 4 0 0" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Pause after broadcaster (sec)"  Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0 6 12 0" />
                                <TextBox   Grid.Row="3" Grid.Column="1" x:Name="TxtTimersBcPause"  Margin="0 4 0 0" />
                            </Grid>
                        </StackPanel>
                    </Border>
                    <DataGrid Grid.Row="3" x:Name="GrdTimers" AutoGenerateColumns="False" CanUserAddRows="False"
                              SelectionMode="Single" SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled}" Width="40" />
                            <DataGridTextColumn Header="Name"    Binding="{Binding Name,    UpdateSourceTrigger=PropertyChanged}" Width="160" />
                            <DataGridTextColumn Header="Message" Binding="{Binding Message, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                            <DataGridTextColumn Header="Group"   Binding="{Binding Group,   UpdateSourceTrigger=PropertyChanged}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Grid.Row="3" x:Name="TxtTimersEmpty"
