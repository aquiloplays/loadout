                                <CheckBox x:Name="ChkCopypasta"  Content="Copypasta detection" Style="{StaticResource ToggleSwitch}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Style="{StaticResource SidebarNavTabItem}">
