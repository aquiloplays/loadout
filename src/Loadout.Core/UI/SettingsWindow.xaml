                                    <Button Content="Remove"        Style="{StaticResource SecondaryButton}" Click="BtnShopRemove_Click"     Margin="0 0 8 0" />
                                    <Button Content="Reset stock"   Style="{StaticResource SecondaryButton}" Click="BtnShopResetStock_Click" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Style="{StaticResource SidebarNavTabItem}">
