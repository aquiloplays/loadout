                            <DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled}" Width="40" />
                            <DataGridTextColumn Header="Name"   Binding="{Binding Name,    UpdateSourceTrigger=PropertyChanged}" Width="180" />
                            <DataGridTextColumn Header="Kind"   Binding="{Binding Kind,    UpdateSourceTrigger=PropertyChanged}" Width="120" />
                            <DataGridTextColumn Header="Target" Binding="{Binding Target,  UpdateSourceTrigger=PropertyChanged}" Width="100" />
                            <DataGridTextColumn Header="Current" Binding="{Binding Current,UpdateSourceTrigger=PropertyChanged}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Grid.Row="2" x:Name="TxtGoalsEmpty"
                               Text="No goals tracked yet — click 'Add goal' to track followers, subs, bits, or a custom number."
                               Style="{StaticResource Muted}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               TextAlignment="Center" MaxWidth="420"
                               IsHitTestVisible="False" Visibility="Collapsed" />
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0 12 0 0">
                        <Button Content="Add goal" Style="{StaticResource SecondaryButton}" Click="BtnGoalAdd_Click"    Margin="0 0 8 0" />
                        <Button Content="Remove"   Style="{StaticResource SecondaryButton}" Click="BtnGoalRemove_Click" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Style="{StaticResource SidebarNavTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource Icon}" Data="{StaticResource IconGeo.Counters}" Margin="0 0 10 0" />
                        <TextBlock Text="Counters" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="32 28">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Custom counters" Style="{StaticResource H1}" />
                    <TextBlock Grid.Row="1" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0 0 0 14">
                        Each counter responds to !&lt;name&gt; in chat. !&lt;name&gt; +1 / -2 / set N / reset.
