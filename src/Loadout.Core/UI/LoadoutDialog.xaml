<Window x:Class="Loadout.UI.LoadoutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loadout"
        Width="460" SizeToContent="Height"
        MinWidth="380" MaxWidth="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontFamily="Segoe UI"
        FontSize="13"
        Background="{DynamicResource Brush.Bg.Window}"
        Foreground="#EFEFF1"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextElement.Foreground="#EFEFF1">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Loadout;component/UI/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="22 18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Optional kicker line — set by code-behind to "warning",
             "error", "info", etc. Acts as a small accent strip. -->
        <Border Grid.Row="0" x:Name="Kicker" Padding="0 0 0 0" Visibility="Collapsed" Margin="0 0 0 8">
            <TextBlock x:Name="TxtKicker" FontSize="10" FontWeight="Bold" Foreground="{StaticResource Brush.Accent}" />
        </Border>

        <StackPanel Grid.Row="1">
            <TextBlock x:Name="TxtTitle"  Style="{StaticResource H2}" Margin="0 0 0 6" />
            <TextBlock x:Name="TxtBody"   TextWrapping="Wrap" LineHeight="20" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 22 0 0">
            <Button x:Name="BtnCancel" Content="Cancel" Style="{StaticResource SecondaryButton}"
                    Margin="0 0 8 0" Click="BtnCancel_Click" Visibility="Collapsed" />
            <Button x:Name="BtnOk"     Content="OK"     Style="{StaticResource PrimaryButton}"
                    Click="BtnOk_Click" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
