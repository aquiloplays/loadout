<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        aquilo.gg / StreamFusion brand palette.
        Pulled from StreamFusion/index.html :root vars so Loadout reads as part
        of the same product family. Don't edit individual colors in isolation —
        update both apps if the brand evolves.
    -->

    <!-- Surfaces -->
    <Color x:Key="Bg.Primary">#0E0E10</Color>
    <Color x:Key="Bg.Surface">#18181B</Color>
    <Color x:Key="Bg.Surface2">#1F1F23</Color>
    <Color x:Key="Bg.Surface3">#26262C</Color>
    <Color x:Key="Border.Default">#2A2A30</Color>

    <!-- Text -->
    <Color x:Key="Fg.Primary">#EFEFF1</Color>
    <Color x:Key="Fg.Muted">#ADADB8</Color>

    <!-- Brand accent (SF blue) -->
    <Color x:Key="Accent.Primary">#3A86FF</Color>
    <Color x:Key="Accent.Hover">#5A9CFF</Color>
    <Color x:Key="Accent.Pressed">#2A6FE0</Color>
    <Color x:Key="Accent.Faint">#3A86FF22</Color>

    <!-- Platforms -->
    <Color x:Key="Platform.Twitch">#9147FF</Color>
    <Color x:Key="Platform.YouTube">#FF0000</Color>
    <Color x:Key="Platform.TikTok">#00F2EA</Color>
    <Color x:Key="Platform.Kick">#53FC18</Color>

    <!-- Status -->
    <Color x:Key="Status.Success">#3FB950</Color>
    <Color x:Key="Status.Warn">#F0883E</Color>
    <Color x:Key="Status.Error">#F85149</Color>
    <Color x:Key="Status.Event">#F0B429</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="Brush.Bg.Primary"   Color="{StaticResource Bg.Primary}" />
    <SolidColorBrush x:Key="Brush.Bg.Surface"   Color="{StaticResource Bg.Surface}" />
    <SolidColorBrush x:Key="Brush.Bg.Surface2"  Color="{StaticResource Bg.Surface2}" />
    <SolidColorBrush x:Key="Brush.Bg.Surface3"  Color="{StaticResource Bg.Surface3}" />
    <SolidColorBrush x:Key="Brush.Border"       Color="{StaticResource Border.Default}" />
    <SolidColorBrush x:Key="Brush.Fg.Primary"   Color="{StaticResource Fg.Primary}" />
    <SolidColorBrush x:Key="Brush.Fg.Muted"     Color="{StaticResource Fg.Muted}" />
    <SolidColorBrush x:Key="Brush.Accent"       Color="{StaticResource Accent.Primary}" />
    <SolidColorBrush x:Key="Brush.Accent.Hover" Color="{StaticResource Accent.Hover}" />
    <SolidColorBrush x:Key="Brush.Accent.Faint" Color="{StaticResource Accent.Faint}" />
    <SolidColorBrush x:Key="Brush.Twitch"       Color="{StaticResource Platform.Twitch}" />
    <SolidColorBrush x:Key="Brush.YouTube"      Color="{StaticResource Platform.YouTube}" />
    <SolidColorBrush x:Key="Brush.TikTok"       Color="{StaticResource Platform.TikTok}" />
    <SolidColorBrush x:Key="Brush.Kick"         Color="{StaticResource Platform.Kick}" />
    <SolidColorBrush x:Key="Brush.Success"      Color="{StaticResource Status.Success}" />
    <SolidColorBrush x:Key="Brush.Warn"         Color="{StaticResource Status.Warn}" />
    <SolidColorBrush x:Key="Brush.Error"        Color="{StaticResource Status.Error}" />

    <!-- Window default -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource Brush.Bg.Primary}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Fg.Primary}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize"   Value="13" />
    </Style>

    <!-- Headings -->
    <Style x:Key="H1" TargetType="TextBlock">
        <Setter Property="FontSize"     Value="22" />
        <Setter Property="FontWeight"   Value="SemiBold" />
        <Setter Property="Foreground"   Value="{StaticResource Brush.Fg.Primary}" />
        <Setter Property="Margin"       Value="0 0 0 8" />
    </Style>
    <Style x:Key="H2" TargetType="TextBlock">
        <Setter Property="FontSize"     Value="15" />
        <Setter Property="FontWeight"   Value="SemiBold" />
        <Setter Property="Foreground"   Value="{StaticResource Brush.Fg.Primary}" />
        <Setter Property="Margin"       Value="0 0 0 6" />
    </Style>
    <Style x:Key="Muted" TargetType="TextBlock">
        <Setter Property="Foreground"   Value="{StaticResource Brush.Fg.Muted}" />
        <Setter Property="FontSize"     Value="12" />
    </Style>
    <Style x:Key="Wordmark" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="20" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Fg.Primary}" />
    </Style>

    <!-- Primary button -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource Brush.Accent}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="16 8" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush.Accent.Hover}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Secondary button -->
    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="{StaticResource Brush.Bg.Surface2}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Fg.Primary}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8"
                            BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush.Bg.Surface3}" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TextBox -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource Brush.Bg.Surface}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Fg.Primary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10 7" />
        <Setter Property="CaretBrush" Value="{StaticResource Brush.Accent}" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="SelectionBrush" Value="{StaticResource Brush.Accent.Faint}" />
    </Style>

    <!-- ComboBox -->
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource Brush.Bg.Surface}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Fg.Primary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
        <Setter Property="Padding" Value="8 6" />
        <Setter Property="MinHeight" Value="32" />
    </Style>

    <!-- Card -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Brush.Bg.Surface}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <!-- Toggle -->
    <Style x:Key="ToggleRow" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource Brush.Fg.Primary}" />
        <Setter Property="Margin" Value="0 4" />
    </Style>

    <!-- TabControl -->
    <Style TargetType="TabControl">
        <Setter Property="Background" Value="{StaticResource Brush.Bg.Primary}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style TargetType="TabItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Fg.Muted}" />
        <Setter Property="Padding" Value="14 8" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="bd" BorderThickness="0 0 0 2" BorderBrush="Transparent"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter ContentSource="Header" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                            <Setter Property="Foreground" Value="{StaticResource Brush.Fg.Primary}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Brush.Fg.Primary}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
