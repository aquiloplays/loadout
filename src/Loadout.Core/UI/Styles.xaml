<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        aquilo.gg / StreamFusion brand palette + premium WPF treatment.
        Pulled from StreamFusion/index.html :root vars so Loadout reads
        as part of the same product family. If you change a brand color
        here, change it in StreamFusion too.

        Polish layer adds: focus glow, drop shadows on cards, smooth
        easing on hovers, custom ScrollBar template (the WPF default
        looks like Windows 7), refined CheckBox + ComboBox treatment.
    -->

    <!-- Surfaces -->
    <Color x:Key="Bg.Primary">#0E0E10</Color>
    <Color x:Key="Bg.Surface">#18181B</Color>
    <Color x:Key="Bg.Surface2">#1F1F23</Color>
    <Color x:Key="Bg.Surface3">#26262C</Color>
    <Color x:Key="Border.Default">#2A2A30</Color>
    <Color x:Key="Border.Subtle">#222226</Color>

    <!-- Text -->
    <Color x:Key="Fg.Primary">#EFEFF1</Color>
    <Color x:Key="Fg.Muted">#ADADB8</Color>
    <Color x:Key="Fg.Faint">#7A7A85</Color>

    <!-- Brand accent (SF blue) -->
    <Color x:Key="Accent.Primary">#3A86FF</Color>
    <Color x:Key="Accent.Hover">#5A9CFF</Color>
    <Color x:Key="Accent.Pressed">#2A6FE0</Color>
    <Color x:Key="Accent.Faint">#3A86FF22</Color>
    <Color x:Key="Accent.Glow">#3A86FF66</Color>

    <!-- Platforms -->
    <Color x:Key="Platform.Twitch">#9147FF</Color>
    <Color x:Key="Platform.YouTube">#FF0000</Color>
    <Color x:Key="Platform.TikTok">#00F2EA</Color>
    <Color x:Key="Platform.Kick">#53FC18</Color>

    <!-- Status -->
    <Color x:Key="Status.Success">#3FB950</Color>
    <Color x:Key="Status.Warn">#F0883E</Color>
    <Color x:Key="Status.Error">#F85149</Color>
    <Color x:Key="Status.Event">#F0B429</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="Brush.Bg.Primary"   Color="{StaticResource Bg.Primary}" />
    <SolidColorBrush x:Key="Brush.Bg.Surface"   Color="{StaticResource Bg.Surface}" />
    <SolidColorBrush x:Key="Brush.Bg.Surface2"  Color="{StaticResource Bg.Surface2}" />
    <SolidColorBrush x:Key="Brush.Bg.Surface3"  Color="{StaticResource Bg.Surface3}" />
    <SolidColorBrush x:Key="Brush.Border"       Color="{StaticResource Border.Default}" />
    <SolidColorBrush x:Key="Brush.Border.Subtle" Color="{StaticResource Border.Subtle}" />
    <SolidColorBrush x:Key="Brush.Fg.Primary"   Color="{StaticResource Fg.Primary}" />
    <SolidColorBrush x:Key="Brush.Fg.Muted"     Color="{StaticResource Fg.Muted}" />
    <SolidColorBrush x:Key="Brush.Fg.Faint"     Color="{StaticResource Fg.Faint}" />
    <SolidColorBrush x:Key="Brush.Accent"       Color="{StaticResource Accent.Primary}" />
    <SolidColorBrush x:Key="Brush.Accent.Hover" Color="{StaticResource Accent.Hover}" />
    <SolidColorBrush x:Key="Brush.Accent.Pressed" Color="{StaticResource Accent.Pressed}" />
    <SolidColorBrush x:Key="Brush.Accent.Faint" Color="{StaticResource Accent.Faint}" />
    <SolidColorBrush x:Key="Brush.Accent.Glow"  Color="{StaticResource Accent.Glow}" />
    <SolidColorBrush x:Key="Brush.Twitch"       Color="{StaticResource Platform.Twitch}" />
    <SolidColorBrush x:Key="Brush.YouTube"      Color="{StaticResource Platform.YouTube}" />
    <SolidColorBrush x:Key="Brush.TikTok"       Color="{StaticResource Platform.TikTok}" />
    <SolidColorBrush x:Key="Brush.Kick"         Color="{StaticResource Platform.Kick}" />
    <SolidColorBrush x:Key="Brush.Success"      Color="{StaticResource Status.Success}" />
    <SolidColorBrush x:Key="Brush.Warn"         Color="{StaticResource Status.Warn}" />
    <SolidColorBrush x:Key="Brush.Error"        Color="{StaticResource Status.Error}" />

    <!-- Card drop shadows -->
    <DropShadowEffect x:Key="Shadow.Card" Color="Black" BlurRadius="20" ShadowDepth="6" Opacity="0.45" Direction="270" />
    <DropShadowEffect x:Key="Shadow.Window" Color="Black" BlurRadius="32" ShadowDepth="0" Opacity="0.55" />

    <!-- Window default -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource Brush.Bg.Primary}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Fg.Primary}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize"   Value="13" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextOptions.TextRenderingMode"  Value="ClearType" />
    </Style>

    <!-- Headings -->
    <Style x:Key="H1" TargetType="TextBlock">
        <Setter Property="FontSize"     Value="24" />
        <Setter Property="FontWeight"   Value="SemiBold" />
        <Setter Property="Foreground"   Value="{StaticResource Brush.Fg.Primary}" />
        <Setter Property="Margin"       Value="0 0 0 10" />
    </Style>
    <Style x:Key="H2" TargetType="TextBlock">
        <Setter Property="FontSize"     Value="15" />
        <Setter Property="FontWeight"   Value="SemiBold" />
        <Setter Property="Foreground"   Value="{StaticResource Brush.Fg.Primary}" />
        <Setter Property="Margin"       Value="0 0 0 6" />
    </Style>
    <Style x:Key="Muted" TargetType="TextBlock">
        <Setter Property="Foreground"   Value="{StaticResource Brush.Fg.Muted}" />
        <Setter Property="FontSize"     Value="12" />
    </Style>
    <Style x:Key="Wordmark" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="20" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Fg.Primary}" />
    </Style>

    <!-- Primary button - smooth easing on hover, scale on press -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource Brush.Accent}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="18 9" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1" CenterX="0.5" CenterY="0.5" />
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bd"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="{StaticResource Accent.Hover}" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bd"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="{StaticResource Accent.Primary}" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="0.97" Duration="0:0:0.08" />
                                        <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="0.97" Duration="0:0:0.08" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.12" />
                                        <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.12" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Secondary button -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource Brush.Bg.Surface2}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Fg.Primary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="18 9" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8"
                            BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                            Padding="{TemplateBinding Padding}">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1" CenterX="0.5" CenterY="0.5" />
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bd"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="{StaticResource Bg.Surface3}" Duration="0:0:0.15" />
                                        <ColorAnimation Storyboard.TargetName="bd"
                                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                        To="{StaticResource Accent.Primary}" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bd"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="{StaticResource Bg.Surface2}" Duration="0:0:0.18" />
                                        <ColorAnimation Storyboard.TargetName="bd"
                                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                        To="{StaticResource Border.Default}" Duration="0:0:0.18" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="0.97" Duration="0:0:0.08" />
                                        <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="0.97" Duration="0:0:0.08" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.12" />
                                        <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.12" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TextBox - focus glow -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource Brush.Bg.Surface}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Fg.Primary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="11 8" />
        <Setter Property="CaretBrush" Value="{StaticResource Brush.Accent}" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="SelectionBrush" Value="{StaticResource Brush.Accent.Faint}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Padding="{TemplateBinding Padding}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Focusable="False" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                            <Setter TargetName="bd" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#3A86FF" BlurRadius="10" ShadowDepth="0" Opacity="0.45" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="#3F3F45" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox -->
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource Brush.Bg.Surface}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Fg.Primary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
        <Setter Property="Padding" Value="10 6" />
        <Setter Property="MinHeight" Value="34" />
    </Style>

    <!-- Card with drop shadow -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Brush.Bg.Surface}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="18" />
        <Setter Property="Effect" Value="{StaticResource Shadow.Card}" />
    </Style>

    <!-- Toggle (CheckBox) - refined with smooth check animation -->
    <Style x:Key="ToggleRow" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource Brush.Fg.Primary}" />
        <Setter Property="Margin" Value="0 5" />
        <Setter Property="Padding" Value="8 0 0 0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="box" Width="18" Height="18" CornerRadius="4"
                                Background="{StaticResource Brush.Bg.Surface}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                VerticalAlignment="Center">
                            <Path x:Name="check" Stretch="Uniform" Width="11" Height="11"
                                  Stroke="White" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M 0 5 L 4 9 L 11 1" Opacity="0" />
                        </Border>
                        <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"
                                          TextElement.FontSize="13" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="box" Property="Background" Value="{StaticResource Brush.Accent}" />
                            <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                            <Setter TargetName="check" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TabControl + TabItem - accent underline on selected -->
    <Style TargetType="TabControl">
        <Setter Property="Background" Value="{StaticResource Brush.Bg.Primary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>
    <Style TargetType="TabItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Fg.Muted}" />
        <Setter Property="Padding" Value="16 10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="bd" BorderThickness="0 0 0 2" BorderBrush="Transparent"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter ContentSource="Header" RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                            <Setter Property="Foreground" Value="{StaticResource Brush.Fg.Primary}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Brush.Fg.Primary}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Custom ScrollBar - slim, accent thumb on hover -->
    <Style x:Key="ScrollThumbStyle" TargetType="Thumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="thumb" Background="#3F3F45" CornerRadius="3" Margin="2" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="thumb" Property="Background" Value="{StaticResource Brush.Accent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="10" />
        <Setter Property="MinWidth" Value="10" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ScrollThumbStyle}" />
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False" />
                            </Track.IncreaseRepeatButton>
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False" />
                            </Track.DecreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto" />
                <Setter Property="Height" Value="10" />
                <Setter Property="MinHeight" Value="10" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid Background="Transparent">
                                <Track x:Name="PART_Track" IsDirectionReversed="False">
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ScrollThumbStyle}" />
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageRightCommand" Opacity="0" Focusable="False" />
                                    </Track.IncreaseRepeatButton>
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageLeftCommand" Opacity="0" Focusable="False" />
                                    </Track.DecreaseRepeatButton>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- DataGrid -->
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource Brush.Bg.Surface}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Fg.Primary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource Brush.Border.Subtle}" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="RowBackground" Value="Transparent" />
        <Setter Property="AlternatingRowBackground" Value="#1B1B1F" />
        <Setter Property="RowHeight" Value="36" />
        <Setter Property="ColumnHeaderHeight" Value="36" />
        <Setter Property="FontSize" Value="13" />
    </Style>
    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource Brush.Bg.Surface2}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Fg.Muted}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="0 0 0 1" />
        <Setter Property="Padding" Value="12 8" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="11" />
    </Style>
    <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.Accent.Faint}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.Accent.Faint}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.Fg.Primary}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Window-open fade-in storyboard. Animates ONLY Opacity (and the
         window starts at Opacity=1 so it's still visible if this storyboard
         never fires). The previous version animated a TranslateTransform
         target that required matching shape on the Window's RenderTransform;
         when that mismatched, WPF threw on Begin and the window was left at
         Opacity=0 - i.e. invisible. Lesson: animate properties that are
         already there, don't introduce new shape from the storyboard. -->
    <Storyboard x:Key="WindowFadeIn">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0.85" To="1" Duration="0:0:0.20">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseOut" />
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

</ResourceDictionary>
