<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Loadout vector icon library. Every icon in the app is rendered from
        a path geometry defined here - no emoji, no PNG sprites, no font
        glyphs. Stylistic rules:

            - 24×24 viewBox source, rendered at 16-20px (Stretch="Uniform")
            - Stroke-only (no fills) for monoline consistency
            - 1.6 stroke thickness, round caps + joins
            - Brand-color stroke at the call site so dark/light themes work

        Use:

            <Path Style="{StaticResource Icon}" Data="{StaticResource IconGeo.Bolts}" />

        For a tab header that pairs an icon with text, see
        <SidebarTabIcon> in Styles.xaml — it composes both into a clean
        horizontal stack.
    -->

    <!-- ============== Default icon style ==================================
         Calls below specify Width/Height as needed; defaults to 16. -->
    <Style x:Key="Icon" TargetType="Path">
        <Setter Property="Stroke" Value="{DynamicResource Brush.Fg.Primary}" />
        <Setter Property="StrokeThickness" Value="1.6" />
        <Setter Property="Width"  Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="StrokeStartLineCap" Value="Round" />
        <Setter Property="StrokeEndLineCap"   Value="Round" />
        <Setter Property="StrokeLineJoin"     Value="Round" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding"  Value="True" />
        <Setter Property="VerticalAlignment"   Value="Center" />
    </Style>

    <!-- A muted variant for inline accent / decorative icons (e.g. status
         dot suffixes). -->
    <Style x:Key="IconMuted" TargetType="Path" BasedOn="{StaticResource Icon}">
        <Setter Property="Stroke" Value="{DynamicResource Brush.Fg.Muted}" />
    </Style>

    <Style x:Key="IconAccent" TargetType="Path" BasedOn="{StaticResource Icon}">
        <Setter Property="Stroke" Value="{DynamicResource Brush.Accent}" />
    </Style>

    <!-- Brand icon: filled, no stroke - for actual brand logos
         (Discord, X). Caller sets Fill to the brand color. -->
    <Style x:Key="BrandIcon" TargetType="Path">
        <Setter Property="Width"  Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

