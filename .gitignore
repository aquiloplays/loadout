# Build artifacts
bin/
obj/
dist/
*.user
*.suo
.vs/

# Rider / VS Code
.idea/
.vscode/

# NuGet
packages/
*.nupkg

# Local settings
local.json
*.local.json

# OS
Thumbs.db
.DS_Store

# Test output
TestResults/

# Loadout: never commit user data dumps
data-dump/
*.loadout-backup.zip

# Node (discord-bot Worker)
node_modules/

# Cloudflare Wrangler local state + secrets
.wrangler/
.dev.vars

# Local sprite preview output (tools/preview-character.mjs)
tools/preview/
tools/_gen/

# generated art working dirs (Replicate raw candidates)
_jar_art/
_deadline_art/

# Generated art + screenshots dumped at repo root (scratch, regenerable).
# Root-anchored so real tracked assets under assets/, aquilo-site/, etc. are untouched.
/*.png
/*.webp
/*.gif

# Python art-tooling caches
__pycache__/
*.pyc

# Local scratch: preview/screenshot output, KV backups, Claude project config
.hm-shots/
.sk-shots/
.checkin-preview/
kv-backups/
.claude/

# Secrets + local-only config (never commit). Covers *.local such as
# discord-bot/.fallout-admin-secret.local
*.local

# KV backups + local runtime/test state (regenerable, never commit)
.kv-backups/
discord-bot/gear-worn-state.json
discord-bot/mount-test.txt
